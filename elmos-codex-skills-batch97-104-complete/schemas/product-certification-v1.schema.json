{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elmos.dev/schemas/product-certification-v1",
  "type": "object",
  "required": ["schema_version", "release", "scope", "status", "evidence_refs", "board", "limitations", "signature"],
  "properties": {
    "schema_version": {"const": "elmos.product-certification.v1"},
    "release": {"type": "string", "minLength": 1},
    "scope": {
      "type": "object",
      "required": ["environment", "artifact_digests"],
      "properties": {
        "environment": {"type": "string", "minLength": 1},
        "artifact_digests": {"$ref": "#/$defs/digest_array"}
      },
      "additionalProperties": false
    },
    "status": {"enum": ["not_run", "blocked", "experimental", "limited", "ready_for_external_gate", "certified", "revoked"]},
    "evidence_refs": {"$ref": "#/$defs/digest_array"},
    "board": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["role", "identity", "decision_ref"],
        "properties": {
          "role": {"type": "string", "minLength": 1},
          "identity": {"type": "string", "minLength": 1},
          "decision_ref": {"$ref": "#/$defs/digest"}
        },
        "additionalProperties": false
      }
    },
    "limitations": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "signature": {"type": ["object", "null"]}
  },
  "allOf": [
    {
      "if": {"properties": {"status": {"enum": ["ready_for_external_gate", "certified"]}}, "required": ["status"]},
      "then": {
        "properties": {
          "scope": {"properties": {"artifact_digests": {"minItems": 1}}},
          "evidence_refs": {"minItems": 2},
          "board": {"minItems": 2}
        }
      }
    },
    {
      "if": {"properties": {"status": {"const": "certified"}}, "required": ["status"]},
      "then": {"properties": {"signature": {"type": "object", "minProperties": 1}}}
    }
  ],
  "$defs": {
    "digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "digest_array": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/digest"}}
  },
  "additionalProperties": false
}
