{
  "schema_version": 1,
  "extension_key": "migration-intellij",
  "host": "intellij",
  "version": "0.1.0",
  "host_version_range": "TODO-exact-range",
  "protocol_version": "1.0.0",
  "capabilities": [
    "preview",
    "navigation",
    "explain",
    "quick-fix",
    "local-eval"
