{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "elmos.project-synthesis.execution-evidence.v1",
  "title": "ELMOS Execution Evidence",
  "type": "object",
  "required": [
    "schema_version",
    "execution_id",
    "kind",
    "runner",
    "command",
    "started_at",
    "status",
    "artifacts"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "execution_id": {
      "type": "string"
    },
    "kind": {
      "enum": [
        "build",
        "test",
        "startup",
        "smoke",
        "security",
        "deploy",
        "rollback",
        "recovery"
      ]
    },
    "runner": {
      "type": "object"
    },
    "command": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "started_at": {
      "type": "string"
    },
    "finished_at": {
      "type": "string"
    },
    "status": {
      "enum": [
        "passed",
        "failed",
        "cancelled",
        "timed-out",
        "policy-denied"
      ]
    },
    "exit_code": {
      "type": [
        "integer",
        "null"
      ]
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "diagnostics": {
      "type": "array",
      "items": {
        "type": "object"
      }
    }
  }
}