{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "elmos.project-synthesis.ownership-manifest.v1",
  "title": "ELMOS Artifact Ownership Manifest",
  "type": "object",
  "required": [
    "schema_version",
    "entries"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "path",
          "mode",
          "owner",
          "generator",
          "source_refs"
        ],
        "properties": {
          "path": {
            "type": "string"
          },
          "mode": {
            "enum": [
              "managed",
              "protected",
              "user-owned",
              "imported",
              "derived"
            ]
          },
          "owner": {
            "type": "string"
          },
          "generator": {
            "type": "string"
          },
          "source_refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "protected_regions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}