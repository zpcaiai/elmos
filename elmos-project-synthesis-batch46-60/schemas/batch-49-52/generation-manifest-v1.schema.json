{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "elmos.project-synthesis.generation-manifest.v1",
  "title": "ELMOS Generation Manifest",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "blueprint_hash",
    "artifacts",
    "templates",
    "tools",
    "sbom_ref"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "run_id": {
      "type": "string"
    },
    "blueprint_hash": {
      "type": "string"
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "path",
          "fingerprint",
          "ownership",
          "generator",
          "source_refs"
        ],
        "properties": {
          "path": {
            "type": "string"
          },
          "fingerprint": {
            "type": "string"
          },
          "ownership": {
            "enum": [
              "managed",
              "protected",
              "user-owned",
              "imported",
              "derived"
            ]
          },
          "generator": {
            "type": "string"
          },
          "source_refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "template_ref": {
            "type": "string"
          },
          "semantic_symbol_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "templates": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "tools": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "merge": {
      "type": "object"
    },
    "quality": {
      "type": "object"
    },
    "sbom_ref": {
      "type": "string"
    },
    "signature": {
      "type": "string"
    }
  }
}