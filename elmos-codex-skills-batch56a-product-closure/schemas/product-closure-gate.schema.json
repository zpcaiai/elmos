{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "schemaVersion",
    "artifactDigest",
    "programs",
    "decision"
  ],
  "properties": {
    "schemaVersion": {
      "const": "1.0"
    },
    "artifactDigest": {
      "type": "string"
    },
    "programs": {
      "type": "object"
    },
    "p0Failures": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "decision": {
      "enum": [
        "BLOCKED",
        "CONDITIONAL",
        "RELEASE_CANDIDATE",
        "GA"
      ]
    }
  }
}
