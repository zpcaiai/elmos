    "category": "representative",
    "severity": "high",
    "title": "Data Migration and Lineage Gate: Representative path",
    "objective": "Verify complete, reversible where possible, reconciled and lineage-preserving data movement. Scenario 1 applies the representative path variation across at least three materially different language/platform packs.",
    "preconditions": [
      "Use an isolated test tenant/workspace and pinned toolchain profile.",
      "Load approved fixtures and source-package manifest.",
      "Enable full audit, trace and evidence capture."
    ],
    "steps": [
      "Prepare the declared source, target and environment fixture.",
      "Execute the target Skill workflow through the public orchestration contract.",
      "Inject the case-specific variation or failure condition.",
      "Collect outputs, state transitions, logs, traces, diffs and approvals.",
      "Evaluate semantic, safety, security and evidence assertions.",
      "Repeat deterministic positive behavior a second time when applicable."
    ],
    "expected": [
      "The system produces a deterministic machine-readable result.",
      "Every decision and artifact is linked to source inputs and target Skills.",
      "Unsafe or unsupported behavior is blocked rather than approximated silently.",
      "Required evidence is complete, immutable and independently reviewable.",
      "Results are compared across at least three platform families.",
      "Any critical failure blocks the aggregate gate."
    ],
    "required_evidence": [
      "input and environment fingerprints",
      "toolchain and Skill versions",
      "state-transition and decision log",
      "artifact or semantic diff",
      "assertion results",
      "security/safety findings",
      "final disposition and owner"
    ],
    "anti_fraud": [
      "No deleted or disabled failing test.",
      "No broadened tolerance without approved rationale.",
      "No mock substituted for a mandatory real platform integration.",
      "No evidence omitted because it is unfavorable."
    ],
    "tags": [
      "cross-batch",
      "data-migration-lineage-gate",
      "representative"
    ]
