{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "schema_version",
    "project_id",
    "source_commit",
    "assets",
    "toolchains",
    "target_profiles"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "project_id": {
      "type": "string",
      "minLength": 1
    },
    "source_commit": {
      "type": "string",
      "minLength": 7
    },
    "assets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "kind",
          "path",
          "sha256"
        ],
        "properties": {
          "kind": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          }
        }
      }
    },
    "toolchains": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "version"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "version": {
            "type": "string"
          }
        }
      }
    },
    "target_profiles": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}
