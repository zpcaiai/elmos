{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "skill_id",
    "source_commit",
    "environment",
    "commands",
    "artifacts",
    "state",
    "limitations"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "run_id": {
      "type": "string"
    },
    "skill_id": {
      "type": "string",
      "pattern": "^PG[0-9]{3,}$"
    },
    "source_commit": {
      "type": "string"
    },
    "environment": {
      "type": "object"
    },
    "commands": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "command",
          "exit_code"
        ],
        "properties": {
          "command": {
            "type": "string"
          },
          "exit_code": {
            "type": "integer"
          },
          "duration_ms": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "path",
          "sha256"
        ],
        "properties": {
          "path": {
            "type": "string"
          },
          "sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          }
        }
      }
    },
    "state": {
      "enum": [
        "generated",
        "parsed",
        "statically_validated",
        "built",
        "tested",
        "runtime_verified",
        "certified",
        "blocked",
        "failed"
      ]
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "approvals": {
      "type": "array",
      "items": {
        "type": "object"
      }
    }
  },
  "additionalProperties": true
}
