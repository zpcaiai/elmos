{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "skill_id",
    "target_profile",
    "steps",
    "stop_conditions"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "run_id": {
      "type": "string"
    },
    "skill_id": {
      "type": "string",
      "pattern": "^PG[0-9]{3,}$"
    },
    "target_profile": {
      "type": "string"
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "action",
          "consequential"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "action": {
            "type": "string"
          },
          "consequential": {
            "type": "boolean"
          },
          "command": {
            "type": "string"
          },
          "expected_outputs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "stop_conditions": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "approvals": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}
