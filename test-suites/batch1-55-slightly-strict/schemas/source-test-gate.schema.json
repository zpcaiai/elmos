{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elmos.example/schemas/test-gate.json",
  "type": "object",
  "required": [
    "batch",
    "status",
    "p0",
    "criticalP1",
    "ordinaryP1PassRate",
    "evidence"
  ],
  "properties": {
    "batch": {
      "type": "integer",
      "minimum": 1,
      "maximum": 55
    },
    "status": {
      "enum": [
        "PASS",
        "CONDITIONAL",
        "BLOCKED"
      ]
    },
    "p0": {
      "type": "object",
      "required": [
        "total",
        "passed"
      ],
      "properties": {
        "total": {
          "type": "integer"
        },
        "passed": {
          "type": "integer"
        }
      }
    },
    "criticalP1": {
      "type": "object",
      "required": [
        "total",
        "passed"
      ],
      "properties": {
        "total": {
          "type": "integer"
        },
        "passed": {
          "type": "integer"
        }
      }
    },
    "ordinaryP1PassRate": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "mutationScore": {
      "type": [
        "number",
        "null"
      ],
      "minimum": 0,
      "maximum": 1
    },
    "flakyRate": {
      "type": [
        "number",
        "null"
      ],
      "minimum": 0,
      "maximum": 1
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "waivers": {
      "type": "array",
      "items": {
        "type": "object"
      }
    }
  },
  "additionalProperties": true
}