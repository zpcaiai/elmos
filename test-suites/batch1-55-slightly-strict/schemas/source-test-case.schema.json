{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elmos.example/schemas/test-case.json",
  "title": "ELMOS Slightly Strict Test Case",
  "type": "object",
  "required": [
    "id",
    "title",
    "priority",
    "type",
    "given",
    "when",
    "then",
    "evidence"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 3
    },
    "title": {
      "type": "string",
      "minLength": 3
    },
    "priority": {
      "enum": [
        "P0",
        "P1",
        "P2",
        "P3"
      ]
    },
    "type": {
      "type": "string",
      "minLength": 2
    },
    "given": {
      "type": "string",
      "minLength": 5
    },
    "when": {
      "type": "string",
      "minLength": 3
    },
    "then": {
      "type": "string",
      "minLength": 5
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}