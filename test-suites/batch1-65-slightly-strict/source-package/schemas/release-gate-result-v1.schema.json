{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "elmos.release-gate-result.v1",
  "type": "object",
  "required": [
    "decision",
    "profile_id",
    "metrics",
    "blockers"
  ],
  "properties": {
    "decision": {
      "enum": [
        "PASS",
        "FAIL"
      ]
    },
    "profile_id": {
      "type": "string"
    },
    "metrics": {
      "type": "object"
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}