{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "effect",
    "reasons",
    "obligations",
    "policy_version"
  ],
  "properties": {
    "effect": {
      "enum": [
        "allow",
        "deny"
      ]
    },
    "reasons": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "obligations": {
      "type": "array"
    },
    "required_approvals": {
      "type": "array"
    },
    "redactions": {
      "type": "array"
    },
    "limits": {
      "type": "object"
    },
    "policy_version": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
