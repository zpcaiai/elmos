{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/batch34/scale-profile.schema.json",
  "type": "object",
  "required": [
    "schema_version",
    "profile_key",
    "owner",
    "environment",
    "classes",
    "thresholds"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "profile_key": {
      "type": "string"
    },
    "owner": {
      "type": "string"
    },
    "environment": {
      "type": "object",
      "required": [
        "runner_image_digest",
        "regions",
        "service_versions",
        "resource_limits"
      ],
      "additionalProperties": true
    },
    "classes": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "required": [
          "key",
          "repository_count",
          "loc",
          "languages",
          "build_systems",
          "dataset_manifest_ref"
        ],
        "properties": {
          "key": {
            "enum": [
              "million-loc",
              "thousand-repository",
              "mixed-language"
            ]
          },
          "repository_count": {
            "type": "integer",
            "minimum": 1
          },
          "loc": {
            "type": "integer",
            "minimum": 1
          },
          "languages": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "build_systems": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "dataset_manifest_ref": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "thresholds": {
      "type": "object"
    },
    "zero_tolerance": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}
