{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/batch34/dependency-graph.schema.json",
  "type": "object",
  "required": [
    "schema_version",
    "pack_key",
    "graph_version",
    "nodes",
    "edges"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "pack_key": {
      "type": "string"
    },
    "graph_version": {
      "type": "string"
    },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "kind",
          "logical_key",
          "owner",
          "source_refs"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "kind": {
            "enum": [
              "repository",
              "module",
              "package",
              "service",
              "api",
              "event",
              "database",
              "schema",
              "job",
              "deployment",
              "work-unit"
            ]
          },
          "logical_key": {
            "type": "string"
          },
          "owner": {
            "type": "string"
          },
          "source_refs": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        },
        "additionalProperties": true
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "from",
          "to",
          "kind",
          "criticality",
          "confidence",
          "evidence_refs"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "from": {
            "type": "string"
          },
          "to": {
            "type": "string"
          },
          "kind": {
            "enum": [
              "build",
              "package",
              "api",
              "event",
              "data-read",
              "data-write",
              "runtime",
              "release",
              "identity",
              "configuration",
              "test"
            ]
          },
          "criticality": {
            "enum": [
              "P0",
              "P1",
              "P2",
              "P3"
            ]
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "version_constraint": {
            "type": "string"
          },
          "evidence_refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
