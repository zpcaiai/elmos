{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/batch34/work-unit-plan.schema.json",
  "type": "object",
  "required": [
    "schema_version",
    "pack_key",
    "graph_version",
    "units"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "pack_key": {
      "type": "string"
    },
    "graph_version": {
      "type": "string"
    },
    "units": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "owner",
          "tenant_scope",
          "regions",
          "repository_ids",
          "module_refs",
          "partition_key",
          "dependencies",
          "estimated_loc",
          "resource_profile",
          "criticality",
          "entry_gate",
          "exit_gate",
          "evidence_refs"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "owner": {
            "type": "string"
          },
          "tenant_scope": {
            "type": "string"
          },
          "regions": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "repository_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "module_refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "partition_key": {
            "type": "string"
          },
          "dependencies": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "estimated_loc": {
            "type": "integer",
            "minimum": 0
          },
          "resource_profile": {
            "type": "string"
          },
          "criticality": {
            "enum": [
              "P0",
              "P1",
              "P2",
              "P3"
            ]
          },
          "entry_gate": {
            "type": "string"
          },
          "exit_gate": {
            "type": "string"
          },
          "evidence_refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
