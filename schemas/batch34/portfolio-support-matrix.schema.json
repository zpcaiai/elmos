{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/batch34/portfolio-support-matrix.schema.json",
  "type": "object",
  "required": [
    "schema_version",
    "pack_key",
    "capabilities"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "pack_key": {
      "type": "string"
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "key",
          "status",
          "owner",
          "evidence_refs",
          "limitations"
        ],
        "properties": {
          "key": {
            "type": "string"
          },
          "status": {
            "enum": [
              "certified",
              "supported",
              "conditional",
              "experimental",
              "detected-only",
              "blocked"
            ]
          },
          "owner": {
            "type": "string"
          },
          "evidence_refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "limitations": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
