{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "schema_version",
    "pack_key",
    "capabilities"
  ],
  "properties": {
    "schema_version": {
      "type": "integer"
    },
    "pack_key": {
      "type": "string"
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "status",
          "strategy",
          "evidence_refs"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "status": {
            "enum": [
              "certified",
              "supported",
              "conditional",
              "experimental",
              "detected-only",
              "blocked"
            ]
          },
          "strategy": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          },
          "evidence_refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
