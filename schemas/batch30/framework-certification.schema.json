{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "schema_version",
    "pack_key",
    "pack_version",
    "status",
    "gate_results",
    "metrics",
    "evidence_refs"
  ],
  "properties": {
    "status": {
      "enum": [
        "research",
        "experimental",
        "limited",
        "certified",
        "deprecated",
        "blocked"
      ]
    }
  }
}
