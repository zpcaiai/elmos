{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/batch31/database-pack.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "pack_key",
    "version",
    "mode",
    "status",
    "owner",
    "maintenance_owner",
    "data_owner",
    "source",
    "target",
    "scope",
    "paths",
    "gates"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "pack_key": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{1,63}$"
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "enum": [
        "assessment",
        "migration",
        "upgrade",
        "modernization",
        "coexistence"
      ]
    },
    "status": {
      "enum": [
        "research",
        "experimental",
        "limited",
        "certified",
        "deprecated",
        "blocked"
      ]
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "maintenance_owner": {
      "type": "string",
      "minLength": 1
    },
    "data_owner": {
      "type": "string",
      "minLength": 1
    },
    "source": {
      "$ref": "#/$defs/side"
    },
    "target": {
      "$ref": "#/$defs/side"
    },
    "scope": {
      "type": "object",
      "required": [
        "schemas",
        "objects",
        "workload_classes"
      ],
      "properties": {
        "schemas": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "objects": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "workload_classes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "paths": {
      "type": "object",
      "minProperties": 1
    },
    "gates": {
      "type": "object",
      "minProperties": 1
    },
    "review_by": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "$defs": {
    "side": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "engine",
        "versions",
        "edition",
        "dialect",
        "driver_versions",
        "charset",
        "collation",
        "timezone",
        "extensions"
      ],
      "properties": {
        "engine": {
          "type": "string",
          "minLength": 1
        },
        "versions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "edition": {
          "type": "string",
          "minLength": 1
        },
        "dialect": {
          "type": "string",
          "minLength": 1
        },
        "driver_versions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "charset": {
          "type": "string",
          "minLength": 1
        },
        "collation": {
          "type": "string",
          "minLength": 1
        },
        "timezone": {
          "type": "string",
          "minLength": 1
        },
        "extensions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
