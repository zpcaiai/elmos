{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "pack_key",
    "source_snapshot_digest",
    "objects",
    "queries",
    "pipelines",
    "unsupported_extensions"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "pack_key": {
      "type": "string"
    },
    "source_snapshot_digest": {
      "type": "string",
      "minLength": 1
    },
    "objects": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/node"
      }
    },
    "queries": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/node"
      }
    },
    "pipelines": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/node"
      }
    },
    "unsupported_extensions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "source_ref",
          "feature",
          "severity"
        ],
        "properties": {
          "source_ref": {},
          "feature": {
            "type": "string"
          },
          "severity": {
            "enum": [
              "critical",
              "high",
              "medium",
              "low"
            ]
          },
          "reason": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    }
  },
  "$defs": {
    "node": {
      "type": "object",
      "required": [
        "id",
        "kind",
        "logical_name",
        "source_ref",
        "semantics",
        "dependencies"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "logical_name": {
          "type": "string",
          "minLength": 1
        },
        "source_ref": {},
        "semantics": {
          "type": "object"
        },
        "dependencies": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "provider_extension": {
          "type": [
            "object",
            "null"
          ]
        }
      },
      "additionalProperties": true
    }
  }
}
