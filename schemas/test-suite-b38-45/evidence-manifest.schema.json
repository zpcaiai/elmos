{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elmos.example/schemas/test-suite-b38-45/evidence-manifest.schema.json",
  "type": "object", "additionalProperties": false,
  "required": ["manifest_version", "manifest_id", "case_id", "case_digest", "catalog_digest", "artifact_digest", "environment_digest", "execution_kind", "started_at", "finished_at", "executor", "verifier", "authorization_refs", "replay_command", "files", "corpora"],
  "properties": {
    "manifest_version": {"const": 2}, "manifest_id": {"type": "string", "minLength": 1}, "case_id": {"type": "string", "minLength": 1},
    "case_digest": {"$ref": "#/$defs/digest"}, "catalog_digest": {"$ref": "#/$defs/digest"}, "artifact_digest": {"$ref": "#/$defs/digest"}, "environment_digest": {"$ref": "#/$defs/digest"},
    "execution_kind": {"enum": ["real", "approved-equivalent"]}, "started_at": {"type": "string", "format": "date-time"}, "finished_at": {"type": "string", "format": "date-time"},
    "executor": {"$ref": "#/$defs/executor"}, "verifier": {"$ref": "#/$defs/verifier"},
    "authorization_refs": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}}, "replay_command": {"type": "string", "minLength": 1},
    "files": {"type": "array", "minItems": 9, "items": {"$ref": "#/$defs/file"}},
    "corpora": {"type": "array", "minItems": 3, "maxItems": 3, "items": {"$ref": "#/$defs/corpus"}}
  },
  "$defs": {
    "digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "executor": {"type": "object", "additionalProperties": false, "required": ["id", "role"], "properties": {"id": {"type": "string", "minLength": 1}, "role": {"const": "executor"}}},
    "verifier": {"type": "object", "additionalProperties": false, "required": ["id", "role", "independent"], "properties": {"id": {"type": "string", "minLength": 1}, "role": {"const": "independent-verifier"}, "independent": {"const": true}}},
    "file": {"type": "object", "additionalProperties": false, "required": ["role", "path", "sha256", "bytes"], "properties": {"role": {"type": "string", "minLength": 1}, "path": {"type": "string", "minLength": 1}, "sha256": {"$ref": "#/$defs/digest"}, "bytes": {"type": "integer", "minimum": 0}}},
    "corpus": {"type": "object", "additionalProperties": false, "required": ["kind", "digest", "manifest_path", "authoring_access", "attestation_ref", "verifier_id"], "properties": {"kind": {"enum": ["development", "holdout", "representative"]}, "digest": {"$ref": "#/$defs/digest"}, "manifest_path": {"type": "string", "minLength": 1}, "authoring_access": {"type": "boolean"}, "attestation_ref": {"type": "string", "minLength": 1}, "verifier_id": {"type": "string", "minLength": 1}}}
  }
}
