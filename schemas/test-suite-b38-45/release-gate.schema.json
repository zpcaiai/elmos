{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elmos.example/schemas/test-suite-b38-45/release-gate.schema.json",
  "type": "object", "additionalProperties": false,
  "required": ["release_gate_version", "suite_id", "required_design_partners", "required_independent_reviews", "required_domain_gates", "design_partner_evidence", "independent_review_evidence", "domain_gate_evidence", "zero_tolerance_findings"],
  "properties": {
    "release_gate_version": {"const": 2}, "suite_id": {"const": "batch38-45-strict"}, "required_design_partners": {"const": 2}, "required_independent_reviews": {"const": 1},
    "required_domain_gates": {"type": "array", "const": [38, 39, 40, 41, 42, 43, 44, 45]},
    "design_partner_evidence": {"type": "array", "items": {"$ref": "#/$defs/customer"}},
    "independent_review_evidence": {"type": "array", "items": {"$ref": "#/$defs/review"}},
    "domain_gate_evidence": {"type": "array", "items": {"$ref": "#/$defs/domain"}},
    "zero_tolerance_findings": {"type": "array"}
  },
  "$defs": {
    "binding": {"type": "object", "additionalProperties": false, "required": ["evidence_id", "path", "sha256", "bytes", "accepted", "independent", "accepted_at", "verifier_id"], "properties": {"evidence_id": {"type": "string", "minLength": 1}, "path": {"type": "string", "minLength": 1}, "sha256": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}, "bytes": {"type": "integer", "minimum": 1}, "accepted": {"const": true}, "independent": {"const": true}, "accepted_at": {"type": "string", "format": "date-time"}, "verifier_id": {"type": "string", "minLength": 1}}},
    "customer": {"type": "object", "additionalProperties": false, "required": ["evidence_id", "organization_id", "path", "sha256", "bytes", "accepted", "independent", "accepted_at", "verifier_id"], "properties": {"evidence_id": {"type": "string", "minLength": 1}, "organization_id": {"type": "string", "minLength": 1}, "path": {"type": "string", "minLength": 1}, "sha256": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}, "bytes": {"type": "integer", "minimum": 1}, "accepted": {"const": true}, "independent": {"const": true}, "accepted_at": {"type": "string", "format": "date-time"}, "verifier_id": {"type": "string", "minLength": 1}}},
    "review": {"$ref": "#/$defs/binding"},
    "domain": {"type": "object", "additionalProperties": false, "required": ["batch", "path", "sha256", "bytes", "verifier_id"], "properties": {"batch": {"type": "integer", "minimum": 38, "maximum": 45}, "path": {"type": "string", "minLength": 1}, "sha256": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}, "bytes": {"type": "integer", "minimum": 1}, "verifier_id": {"type": "string", "minLength": 1}}}
  }
}
