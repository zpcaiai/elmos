{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.elmos.dev/mature-product/trust-store.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["storeVersion", "keys"],
  "properties": {
    "storeVersion": {"const": 1},
    "keys": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["keyId", "publicKeyPath", "revoked", "authorizedBatches"],
        "properties": {
          "keyId": {"type": "string", "minLength": 1},
          "publicKeyPath": {"type": "string", "minLength": 1},
          "revoked": {"type": "boolean"},
          "authorizedBatches": {"type": "array", "items": {"type": "integer", "minimum": 38, "maximum": 45}, "minItems": 1, "uniqueItems": true}
        }
      }
    }
  }
}
