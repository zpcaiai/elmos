{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.elmos.dev/mature-product/batch44/program.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "batch",
    "packKey",
    "owner",
    "scope",
    "skillIds",
    "status",
    "evidenceRefs",
    "externalOperationExecuted"
  ],
  "properties": {
    "batch": {
      "const": 44
    },
    "packKey": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{2,62}$"
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "scope": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "skillIds": {
      "type": "array",
      "items": {
        "type": "integer",
        "minimum": 1455,
        "maximum": 1474
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "status": {
      "enum": [
        "NOT_RUN",
        "IN_PROGRESS",
        "BLOCKED",
        "COMPLETE"
      ]
    },
    "evidenceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "externalOperationExecuted": {
      "const": false
    }
  }
}
