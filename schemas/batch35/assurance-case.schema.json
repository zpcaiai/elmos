{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "schema_version",
    "case_key",
    "version",
    "owner",
    "top_claim",
    "claims",
    "evidence",
    "residual_risks",
    "approvals"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "case_key": {
      "type": "string"
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "owner": {
      "type": "string"
    },
    "top_claim": {
      "type": "string"
    },
    "claims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "claim_id",
          "statement",
          "status",
          "evidence_refs"
        ],
        "properties": {
          "claim_id": {
            "type": "string"
          },
          "statement": {
            "type": "string"
          },
          "status": {
            "enum": [
              "supported",
              "partially-supported",
              "unsupported",
              "defeated"
            ]
          },
          "evidence_refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "assumptions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "limitations": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": true
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "residual_risks": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "monitoring_obligations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "approvals": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}
