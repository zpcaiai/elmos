{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "schema_version",
    "campaign_key",
    "owner",
    "target_scope",
    "operators",
    "budgets",
    "required_tests"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "campaign_key": {
      "type": "string"
    },
    "owner": {
      "type": "string"
    },
    "target_scope": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "operators": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "key",
          "risk"
        ],
        "properties": {
          "key": {
            "type": "string"
          },
          "risk": {
            "enum": [
              "P0",
              "P1",
              "P2",
              "P3"
            ]
          }
        }
      }
    },
    "budgets": {
      "type": "object"
    },
    "required_tests": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "equivalent_mutant_policy": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
