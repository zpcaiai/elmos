{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "schema_version",
    "model_key",
    "owner",
    "states",
    "initial_state",
    "commands",
    "invariants"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "model_key": {
      "type": "string"
    },
    "owner": {
      "type": "string"
    },
    "states": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "initial_state": {
      "type": "string"
    },
    "commands": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "command",
          "from",
          "to"
        ],
        "properties": {
          "command": {
            "type": "string"
          },
          "from": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "to": {
            "type": "string"
          },
          "guard": {
            "type": "string"
          },
          "effects": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": true
      }
    },
    "invariants": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "forbidden_transitions": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "timeouts": {
      "type": "array",
      "items": {
        "type": "object"
      }
    }
  },
  "additionalProperties": true
}
