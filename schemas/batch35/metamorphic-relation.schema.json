{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "schema_version",
    "relation_id",
    "claim_id",
    "owner",
    "preconditions",
    "transformation",
    "expected_relation",
    "oracle_refs"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "relation_id": {
      "type": "string"
    },
    "claim_id": {
      "type": "string"
    },
    "owner": {
      "type": "string"
    },
    "preconditions": {
      "type": "array"
    },
    "transformation": {
      "type": "object"
    },
    "expected_relation": {
      "type": "object"
    },
    "oracle_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "non_applicable": {
      "type": "array"
    }
  },
  "additionalProperties": true
}
