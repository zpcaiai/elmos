{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "schema_version",
    "property_id",
    "claim_id",
    "owner",
    "generator",
    "oracle_refs",
    "assertion",
    "replay"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "property_id": {
      "type": "string"
    },
    "claim_id": {
      "type": "string"
    },
    "owner": {
      "type": "string"
    },
    "generator": {
      "type": "object",
      "required": [
        "kind",
        "constraints"
      ],
      "additionalProperties": true
    },
    "oracle_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "assertion": {
      "type": "object"
    },
    "shrinker": {
      "type": "object"
    },
    "replay": {
      "type": "object",
      "required": [
        "seed",
        "command"
      ],
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
