{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "schema_version",
    "profile_key",
    "version",
    "risk_tier",
    "claims",
    "techniques",
    "budgets",
    "stop_conditions"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "profile_key": {
      "type": "string"
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "risk_tier": {
      "enum": [
        "P0",
        "P1",
        "P2",
        "P3"
      ]
    },
    "claims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "claim_id",
          "description",
          "criticality",
          "required_oracles",
          "required_techniques"
        ],
        "properties": {
          "claim_id": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "criticality": {
            "enum": [
              "P0",
              "P1",
              "P2",
              "P3"
            ]
          },
          "required_oracles": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "required_techniques": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": true
      }
    },
    "techniques": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "budgets": {
      "type": "object"
    },
    "stop_conditions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "approvals": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}
