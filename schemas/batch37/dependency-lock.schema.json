{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "schema_version",
    "pack_key",
    "resolution_id",
    "roots",
    "nodes",
    "edges",
    "lock_digest",
    "cycles",
    "revocation_propagation"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "pack_key": {
      "type": "string",
      "minLength": 1
    },
    "resolution_id": {
      "type": "string",
      "minLength": 1
    },
    "roots": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "extension_id",
          "version",
          "digest"
        ],
        "properties": {
          "extension_id": {
            "type": "string",
            "minLength": 1
          },
          "version": {
            "type": "string",
            "minLength": 1
          },
          "digest": {
            "type": "string",
            "pattern": "^sha256:[A-Za-z0-9._:-]+$"
          }
        },
        "additionalProperties": true
      }
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "extension_id",
          "version",
          "digest",
          "status"
        ],
        "properties": {
          "extension_id": {
            "type": "string",
            "minLength": 1
          },
          "version": {
            "type": "string",
            "minLength": 1
          },
          "digest": {
            "type": "string",
            "pattern": "^sha256:[A-Za-z0-9._:-]+$"
          },
          "status": {
            "enum": [
              "active",
              "quarantined",
              "revoked",
              "deprecated"
            ]
          }
        },
        "additionalProperties": true
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "from",
          "to",
          "constraint"
        ],
        "properties": {
          "from": {
            "type": "string",
            "minLength": 1
          },
          "to": {
            "type": "string",
            "minLength": 1
          },
          "constraint": {
            "type": "string",
            "minLength": 1
          },
          "optional": {
            "type": "boolean"
          }
        },
        "additionalProperties": true
      }
    },
    "lock_digest": {
      "type": "string",
      "pattern": "^sha256:[A-Za-z0-9._:-]+$"
    },
    "resolver_version": {
      "type": "string",
      "minLength": 1
    },
    "cycles": {
      "type": "array",
      "maxItems": 0
    },
    "revocation_propagation": {
      "type": "object",
      "required": [
        "enabled",
        "blocked_nodes"
      ],
      "properties": {
        "enabled": {
          "const": true
        },
        "blocked_nodes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": true,
  "$id": "https://example.invalid/batch37/dependency-lock.schema.json"
}
