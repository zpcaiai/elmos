{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "schema_version",
    "pack_key",
    "status",
    "metrics",
    "zero_tolerance",
    "evidence_refs"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "pack_key": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": [
        "research",
        "experimental",
        "limited",
        "certified",
        "blocked"
      ]
    },
    "metrics": {
      "type": "object"
    },
    "zero_tolerance": {
      "type": "object"
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "owner": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": true,
  "$id": "https://example.invalid/batch37/closure-certification.schema.json"
}
