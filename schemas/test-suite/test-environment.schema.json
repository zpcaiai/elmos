{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elmos.dev/schemas/test-suite/test-environment.schema.json",
  "type": "object",
  "required": ["environment_id", "version", "isolated", "toolchains", "network_policy", "data_policy"],
  "properties": {
    "environment_id": {"type": "string", "minLength": 1},
    "version": {"type": "string", "minLength": 1},
    "isolated": {"const": true},
    "toolchains": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object", "required": ["name", "version"],
        "properties": {"name": {"type": "string", "minLength": 1}, "version": {"type": "string", "minLength": 1}},
        "additionalProperties": false
      }
    },
    "network_policy": {
      "type": "object", "required": ["default", "allow"],
      "properties": {"default": {"const": "deny"}, "allow": {"type": "array", "uniqueItems": true}},
      "additionalProperties": false
    },
    "data_policy": {
      "type": "object", "required": ["production_data", "secrets"],
      "properties": {"production_data": {"const": false}, "secrets": {"const": "references-only"}},
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
