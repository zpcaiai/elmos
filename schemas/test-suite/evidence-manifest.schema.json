{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elmos.dev/schemas/test-suite/evidence-manifest.schema.json",
  "title": "Strict evidence manifest",
  "type": "object",
  "required": [
    "manifest_version",
    "manifest_id",
    "case_id",
    "case_digest",
    "catalog_digest",
    "artifact_digest",
    "environment_digest",
    "execution_kind",
    "started_at",
    "finished_at",
    "executor",
    "verifier",
    "authorization_refs",
    "files",
    "corpora"
  ],
  "properties": {
    "manifest_version": {"const": 2},
    "manifest_id": {"type": "string", "minLength": 1},
    "case_id": {"type": "string", "pattern": "^[A-Z0-9-]+$"},
    "case_digest": {"type": "string", "pattern": "^sha256:(?!0{64}$)[0-9a-f]{64}$"},
    "catalog_digest": {"type": "string", "pattern": "^sha256:(?!0{64}$)[0-9a-f]{64}$"},
    "artifact_digest": {"type": "string", "pattern": "^sha256:(?!0{64}$)[0-9a-f]{64}$"},
    "environment_digest": {"type": "string", "pattern": "^sha256:(?!0{64}$)[0-9a-f]{64}$"},
    "execution_kind": {"enum": ["real", "approved-equivalent"]},
    "started_at": {"type": "string", "format": "date-time"},
    "finished_at": {"type": "string", "format": "date-time"},
    "executor": {"$ref": "#/$defs/executor"},
    "verifier": {"$ref": "#/$defs/verifier"},
    "authorization_refs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "files": {
      "type": "array",
      "minItems": 2,
      "items": {"$ref": "#/$defs/file"}
    },
    "corpora": {
      "type": "array",
      "items": {"$ref": "#/$defs/corpus"}
    }
  },
  "$defs": {
    "executor": {
      "type": "object",
      "required": ["id", "role"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "role": {"const": "executor"}
      },
      "additionalProperties": false
    },
    "verifier": {
      "type": "object",
      "required": ["id", "role", "independent"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "role": {"const": "independent-verifier"},
        "independent": {"const": true}
      },
      "additionalProperties": false
    },
    "file": {
      "type": "object",
      "required": ["role", "path", "sha256", "bytes", "immutable"],
      "properties": {
        "role": {"type": "string", "minLength": 1},
        "path": {"type": "string", "minLength": 1},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "bytes": {"type": "integer", "minimum": 1},
        "immutable": {"const": true}
      },
      "additionalProperties": false
    },
    "corpus": {
      "type": "object",
      "required": ["kind", "digest", "independent", "authoring_access"],
      "properties": {
        "kind": {"enum": ["development", "negative", "holdout", "representative"]},
        "digest": {"type": "string", "pattern": "^sha256:(?!0{64}$)[0-9a-f]{64}$"},
        "independent": {"type": "boolean"},
        "authoring_access": {"type": "boolean"}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
