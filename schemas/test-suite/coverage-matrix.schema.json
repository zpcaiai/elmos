{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elmos.dev/schemas/test-suite/coverage-matrix.schema.json",
  "type": "object",
  "required": ["batches", "cross_cutting", "requirements"],
  "properties": {
    "batches": {
      "type": "object",
      "minProperties": 37,
      "maxProperties": 37,
      "patternProperties": {
        "^(?:[1-9]|[12][0-9]|3[0-7])$": {
          "type": "array",
          "minItems": 8,
          "maxItems": 8,
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^B[0-9]{2}-[0-9]{3}$"}
        }
      },
      "additionalProperties": false
    },
    "cross_cutting": {
      "type": "array",
      "minItems": 11,
      "maxItems": 11,
      "uniqueItems": true,
      "items": {"type": "string", "pattern": "^tst-[a-z0-9-]+$"}
    },
    "requirements": {
      "type": "object",
      "required": ["minimum_cases_per_batch", "required_test_types", "required_severities"],
      "properties": {
        "minimum_cases_per_batch": {"const": 8},
        "required_test_types": {
          "type": "array", "minItems": 8, "maxItems": 8, "uniqueItems": true,
          "items": {"enum": ["happy_path", "boundary", "negative", "dependency_failure", "security", "replay_idempotency", "version_drift", "evidence_tamper"]}
        },
        "required_severities": {
          "type": "array", "minItems": 2, "uniqueItems": true,
          "items": {"enum": ["P0", "P1", "P2", "P3"]}
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
