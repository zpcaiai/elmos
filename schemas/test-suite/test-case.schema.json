{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elmos.dev/schemas/test-suite/test-case.schema.json",
  "title": "Strict test case",
  "type": "object",
  "required": [
    "id", "skill", "batches", "capability", "severity", "test_type", "title",
    "preconditions", "steps", "assertions", "evidence_required", "anti_cheat",
    "timeout_seconds", "retries"
  ],
  "properties": {
    "id": {"type": "string", "pattern": "^[A-Z0-9-]+$"},
    "skill": {"type": "string", "pattern": "^[a-z0-9-]{1,64}$"},
    "batches": {
      "type": "array", "minItems": 1, "uniqueItems": true,
      "items": {"type": "integer", "minimum": 1, "maximum": 37}
    },
    "capability": {"type": "string", "minLength": 2},
    "severity": {"enum": ["P0", "P1", "P2", "P3"]},
    "test_type": {
      "enum": [
        "happy_path", "boundary", "negative", "dependency_failure", "security",
        "replay_idempotency", "version_drift", "evidence_tamper"
      ]
    },
    "title": {"type": "string", "minLength": 5},
    "preconditions": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "steps": {"type": "array", "minItems": 3, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "assertions": {"type": "array", "minItems": 3, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "evidence_required": {"type": "array", "minItems": 2, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "anti_cheat": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "timeout_seconds": {"type": "integer", "minimum": 1},
    "retries": {"type": "integer", "minimum": 0, "maximum": 2},
    "holdout_required": {"type": "boolean"},
    "representative_workload_required": {"type": "boolean"}
  },
  "additionalProperties": false
}
