{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/batch32/acceptance-profile.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "profile_key",
    "version",
    "owner",
    "browser_matrix",
    "device_matrix",
    "locales",
    "themes",
    "rendering",
    "visual",
    "accessibility",
    "interaction",
    "performance",
    "seo",
    "i18n",
    "security",
    "p0_journeys",
    "thresholds",
    "exclusions"
  ],
  "properties": {
    "profile_key": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "browser_matrix": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "device_matrix": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "locales": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "themes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "rendering": {
      "type": "object"
    },
    "visual": {
      "type": "object"
    },
    "accessibility": {
      "type": "object"
    },
    "interaction": {
      "type": "object"
    },
    "performance": {
      "type": "object"
    },
    "seo": {
      "type": "object"
    },
    "i18n": {
      "type": "object"
    },
    "security": {
      "type": "object"
    },
    "thresholds": {
      "type": "object"
    },
    "p0_journeys": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "exclusions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
