{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/batch32/ui-interaction-ir.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "pack_key",
    "source_snapshot_digest",
    "routes",
    "views",
    "components",
    "states",
    "actions",
    "effects",
    "forms",
    "bindings",
    "permissions",
    "resources",
    "design_tokens",
    "accessibility",
    "source_map",
    "unknowns"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "pack_key": {
      "type": "string",
      "minLength": 1
    },
    "source_snapshot_digest": {
      "type": "string",
      "minLength": 1
    },
    "routes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/node"
      }
    },
    "views": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/node"
      }
    },
    "components": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/node"
      }
    },
    "states": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/node"
      }
    },
    "actions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/node"
      }
    },
    "effects": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/node"
      }
    },
    "forms": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/node"
      }
    },
    "bindings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/node"
      }
    },
    "permissions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/node"
      }
    },
    "resources": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/node"
      }
    },
    "design_tokens": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/node"
      }
    },
    "accessibility": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/node"
      }
    },
    "source_map": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "node_id",
          "source_refs"
        ],
        "properties": {
          "node_id": {
            "type": "string",
            "minLength": 1
          },
          "source_refs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object"
            }
          }
        },
        "additionalProperties": true
      }
    },
    "unknowns": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "severity",
          "description",
          "owner"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "severity": {
            "enum": [
              "critical",
              "high",
              "medium",
              "low"
            ]
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "owner": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": true
      }
    }
  },
  "$defs": {
    "node": {
      "type": "object",
      "required": [
        "id",
        "kind",
        "name",
        "source_refs"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "source_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object"
          }
        },
        "attributes": {
          "type": "object"
        },
        "references": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "obligations": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    }
  }
}
