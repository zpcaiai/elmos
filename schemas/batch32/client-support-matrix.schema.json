{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/batch32/client-support-matrix.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "pack_key",
    "capabilities"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "pack_key": {
      "type": "string",
      "minLength": 1
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "domain",
          "status",
          "owner",
          "source_versions",
          "target_versions",
          "evidence_refs",
          "reason"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "domain": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "enum": [
              "certified",
              "supported",
              "conditional",
              "experimental",
              "detected-only",
              "blocked"
            ]
          },
          "owner": {
            "type": "string",
            "minLength": 1
          },
          "source_versions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "target_versions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "evidence_refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "reason": {
            "type": "string"
          }
        }
      }
    }
  }
}
