{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "states",
    "transitions"
  ],
  "properties": {
    "states": {
      "type": "array",
      "minItems": 10,
      "items": {
        "type": "string"
      }
    },
    "transitions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "from",
          "to",
          "required_evidence"
        ],
        "properties": {
          "from": {
            "type": "string"
          },
          "to": {
            "type": "string"
          },
          "required_evidence": {
            "type": "array"
          },
          "required_roles": {
            "type": "array"
          },
          "reversible": {
            "type": "boolean"
          }
        }
      }
    }
  },
  "additionalProperties": false
}
