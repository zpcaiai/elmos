{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "documents",
    "exercises",
    "customer_approvals"
  ],
  "properties": {
    "documents": {
      "type": "array",
      "minItems": 8
    },
    "exercises": {
      "type": "array",
      "minItems": 4,
      "items": {
        "type": "object",
        "required": [
          "exercise",
          "status"
        ],
        "properties": {
          "exercise": {
            "type": "string"
          },
          "status": {
            "enum": [
              "not-run",
              "passed",
              "failed",
              "blocked"
            ]
          }
        }
      }
    },
    "customer_approvals": {
      "type": "array"
    }
  },
  "additionalProperties": true
}
