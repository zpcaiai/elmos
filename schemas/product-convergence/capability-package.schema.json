{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "package_id",
    "package_type",
    "version",
    "status",
    "ownership",
    "compatibility",
    "evidence"
  ],
  "properties": {
    "package_id": {
      "type": "string",
      "minLength": 3
    },
    "package_type": {
      "enum": [
        "core",
        "language-route",
        "framework",
        "database",
        "client",
        "cloud",
        "verification",
        "extension",
        "vertical",
        "deployment",
        "agent",
        "commercial"
      ]
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+([+-].+)?$"
    },
    "status": {
      "enum": [
        "draft",
        "experimental",
        "limited",
        "certified",
        "deprecated",
        "retired",
        "revoked",
        "blocked"
      ]
    },
    "ownership": {
      "type": "object",
      "required": [
        "product_owner",
        "engineering_owner",
        "maintenance_owner"
      ],
      "properties": {
        "product_owner": {
          "type": "string"
        },
        "engineering_owner": {
          "type": "string"
        },
        "security_owner": {
          "type": "string"
        },
        "maintenance_owner": {
          "type": "string"
        }
      }
    },
    "compatibility": {
      "type": "object"
    },
    "dependencies": {
      "type": "array"
    },
    "policies": {
      "type": "array"
    },
    "evidence": {
      "type": "array"
    },
    "certification": {
      "type": "object"
    },
    "economics": {
      "type": "object"
    }
  },
  "additionalProperties": true
}
