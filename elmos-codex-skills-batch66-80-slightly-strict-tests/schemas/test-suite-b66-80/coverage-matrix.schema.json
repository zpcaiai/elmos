{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "coverage-matrix.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "suite_id",
    "source_package",
    "source_skill_count",
    "source_skills",
    "cross_cutting_case_ids"
  ],
  "properties": {
    "suite_id": {
      "type": "string"
    },
    "source_package": {
      "type": "object"
    },
    "source_skill_count": {
      "const": 195
    },
    "source_skills": {
      "type": "array",
      "minItems": 195,
      "maxItems": 195
    },
    "cross_cutting_case_ids": {
      "type": "array",
      "minItems": 60,
      "maxItems": 60
    }
  }
}
