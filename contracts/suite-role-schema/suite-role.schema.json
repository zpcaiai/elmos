{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.elmos.local/suite-role/v1",
  "title": "Suite Role Mapping",
  "type": "object",
  "required": ["schemaVersion", "mappingId", "sourceTechnicalRole", "businessDuties", "targetTechnicalRole", "validationStatus", "sodStatus"],
  "properties": {
    "schemaVersion": {"const": "1.0"},
    "mappingId": {"type": "string", "minLength": 1},
    "sourceTechnicalRole": {"type": "string", "minLength": 1},
    "businessDuties": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "targetTechnicalRole": {"type": "string", "minLength": 1},
    "validationStatus": {"enum": ["VALIDATED", "CANDIDATE", "FAILED", "UNKNOWN"]},
    "sodStatus": {"enum": ["NO_CONFLICT", "CONFLICT", "CONFLICT_WITH_CONTROL", "ACCEPTED_EXCEPTION", "UNKNOWN"]},
    "negativeTestEvidenceRefs": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": false
}
