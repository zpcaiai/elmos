{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elmos.io/contracts/behavior-equivalence/equivalence-run-manifest.schema.json",
  "title": "Batch 9 equivalence run manifest",
  "type": "object",
  "required": ["equivalence_run_id", "migration_id", "source_snapshot_id", "target_snapshot_id", "batch8_eligible", "source_runtime", "target_runtime", "modules", "scenarios", "policy", "observed_at"],
  "properties": {
    "equivalence_run_id": {"type": "string", "minLength": 1},
    "migration_id": {"type": "string", "minLength": 1},
    "source_snapshot_id": {"type": "string", "minLength": 1},
    "target_snapshot_id": {"type": "string", "minLength": 1},
    "batch8_eligible": {"const": true},
    "source_runtime": {"$ref": "#/$defs/runtime"},
    "target_runtime": {"$ref": "#/$defs/runtime"},
    "modules": {"type": "array", "minItems": 1, "items": {"type": "object"}},
    "scenarios": {"type": "array", "minItems": 1, "items": {"type": "object"}},
    "observation_points": {"type": "array", "items": {"type": "object"}},
    "obligations": {"type": "array", "items": {"type": "object"}},
    "normalization_rules": {"type": "array", "items": {"type": "object"}},
    "tolerances": {"type": "array", "items": {"type": "object"}},
    "approved_changes": {"type": "array", "items": {"type": "object"}},
    "golden_masters": {"type": "array", "items": {"type": "object"}},
    "policy": {"type": "object", "required": ["required_clean_runs"], "properties": {"required_clean_runs": {"type": "integer", "minimum": 2}}},
    "observed_at": {"type": "string", "format": "date-time"}
  },
  "$defs": {
    "runtime": {
      "type": "object",
      "required": ["role", "snapshot_id", "runtime_version", "environment_id", "mutable_resources", "production_access_allowed", "evidence_refs"],
      "properties": {
        "role": {"enum": ["SOURCE", "TARGET"]},
        "snapshot_id": {"type": "string", "minLength": 1},
        "runtime_version": {"type": "string", "minLength": 1},
        "environment_id": {"type": "string", "minLength": 1},
        "mutable_resources": {"type": "object", "additionalProperties": {"type": "string", "minLength": 1}},
        "production_access_allowed": {"const": false},
        "evidence_refs": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}
      },
      "additionalProperties": false
    }
  }
}
