{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elmos.io/contracts/behavior-equivalence/observable-behavior.schema.json",
  "title": "Observable behavior record",
  "type": "object",
  "required": ["observation_id", "scenario_id", "module_id", "system_role", "observation_type", "raw_ref", "raw_hash", "canonical_ref", "canonical_hash", "collector_status", "sensitive_data_redacted", "evidence_refs"],
  "properties": {
    "observation_id": {"type": "string", "minLength": 1},
    "scenario_id": {"type": "string", "minLength": 1},
    "module_id": {"type": "string", "minLength": 1},
    "system_role": {"enum": ["SOURCE", "TARGET"]},
    "observation_type": {"$ref": "#/$defs/type"},
    "raw_ref": {"type": "string", "minLength": 1},
    "raw_hash": {"type": "string", "pattern": "^[A-Fa-f0-9]{64}$"},
    "canonical_ref": {"type": "string", "minLength": 1},
    "canonical_hash": {"type": "string", "pattern": "^[A-Fa-f0-9]{64}$"},
    "facts": {"type": "object", "additionalProperties": {"type": "string"}},
    "collector_status": {"enum": ["COMPLETE", "FAILED", "INCOMPLETE"]},
    "sensitive_data_redacted": {"const": true},
    "evidence_refs": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}
  },
  "additionalProperties": false,
  "$defs": {"type": {"enum": ["RETURN_VALUE", "HTTP_RESPONSE", "DATABASE_STATE", "DATABASE_WRITE_TRACE", "MESSAGE_EVENT", "FILE_OUTPUT", "OBJECT_STORAGE_OUTPUT", "CACHE_STATE", "EXTERNAL_CALL", "EXCEPTION", "LOG", "AUDIT", "METRIC", "RESOURCE_LIFECYCLE", "CONCURRENCY"]}}
}
