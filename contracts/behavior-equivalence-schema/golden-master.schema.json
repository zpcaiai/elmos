{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elmos.io/contracts/behavior-equivalence/golden-master.schema.json",
  "title": "Versioned Golden Master",
  "type": "object",
  "required": ["golden_id", "scenario_id", "source_snapshot_id", "environment_hash", "input_hash", "initial_state_hash", "raw_observation_ref", "canonical_observation_ref", "normalization_profile_id", "status"],
  "properties": {
    "golden_id": {"type": "string", "minLength": 1}, "scenario_id": {"type": "string", "minLength": 1},
    "source_snapshot_id": {"type": "string", "minLength": 1},
    "environment_hash": {"type": "string", "pattern": "^[A-Fa-f0-9]{64}$"},
    "input_hash": {"type": "string", "pattern": "^[A-Fa-f0-9]{64}$"},
    "initial_state_hash": {"type": "string", "pattern": "^[A-Fa-f0-9]{64}$"},
    "raw_observation_ref": {"type": "string", "minLength": 1}, "canonical_observation_ref": {"type": "string", "minLength": 1},
    "normalization_profile_id": {"type": "string", "minLength": 1},
    "status": {"enum": ["CANDIDATE", "CAPTURED", "REVIEWED", "APPROVED", "DEPRECATED", "INVALIDATED", "SUPERSEDED", "REJECTED"]},
    "reviewer": {"type": ["string", "null"]}, "approval_evidence_ref": {"type": ["string", "null"]}
  },
  "allOf": [{"if": {"properties": {"status": {"enum": ["REVIEWED", "APPROVED"]}}}, "then": {"required": ["reviewer", "approval_evidence_ref"], "properties": {"reviewer": {"type": "string", "minLength": 1}, "approval_evidence_ref": {"type": "string", "minLength": 1}}}}],
  "additionalProperties": false
}
