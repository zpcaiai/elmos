{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elmos.io/contracts/behavior-equivalence/normalization-rule.schema.json",
  "title": "Behavior canonicalization rule",
  "type": "object",
  "required": ["rule_id", "version", "observation_type", "field_path", "transformation", "semantic_impact_none", "conditional"],
  "properties": {
    "rule_id": {"type": "string", "minLength": 1},
    "version": {"type": "string", "minLength": 1},
    "observation_type": {"type": "string", "minLength": 1},
    "field_path": {"type": "string", "minLength": 1},
    "transformation": {"type": "string", "minLength": 1},
    "semantic_impact_none": {"const": true},
    "conditional": {"type": "boolean"},
    "approval_evidence_ref": {"type": ["string", "null"]}
  },
  "allOf": [{"if": {"properties": {"conditional": {"const": true}}}, "then": {"required": ["approval_evidence_ref"], "properties": {"approval_evidence_ref": {"type": "string", "minLength": 1}}}}],
  "additionalProperties": false
}
