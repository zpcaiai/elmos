{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elmos.io/contracts/behavior-equivalence/comparison-record.schema.json",
  "title": "Unified behavioral comparison record",
  "type": "object",
  "required": ["comparison_id", "scenario_id", "module_id", "source_observation_id", "target_observation_id", "observation_type", "raw_difference_ref", "canonical_difference_ref", "oracle_results", "status", "severity", "root_cause", "obligation_ids", "evidence_id", "decision_origin", "flaky", "source_target_trace_linked"],
  "properties": {
    "comparison_id": {"type": "string", "minLength": 1}, "scenario_id": {"type": "string", "minLength": 1}, "module_id": {"type": "string", "minLength": 1},
    "source_observation_id": {"type": "string", "minLength": 1}, "target_observation_id": {"type": "string", "minLength": 1},
    "observation_type": {"type": "string", "minLength": 1}, "raw_difference_ref": {"type": "string", "minLength": 1}, "canonical_difference_ref": {"type": "string", "minLength": 1},
    "oracle_results": {"type": "array", "minItems": 1, "items": {"type": "object", "required": ["oracle_id", "status", "required"], "properties": {"oracle_id": {"type": "string", "minLength": 1}, "status": {"enum": ["PASSED", "FAILED", "UNKNOWN", "NOT_RUN"]}, "required": {"type": "boolean"}, "detail": {"type": ["string", "null"]}, "evidence_refs": {"type": "array", "items": {"type": "string"}}}, "additionalProperties": false}},
    "status": {"enum": ["EQUIVALENT", "EQUIVALENT_AFTER_NORMALIZATION", "WITHIN_TOLERANCE", "APPROVED_CHANGE", "REGRESSION", "UNKNOWN", "NOT_COMPARABLE"]},
    "severity": {"enum": ["INFO", "LOW", "MEDIUM", "HIGH", "CRITICAL"]}, "root_cause": {"type": "string", "minLength": 1},
    "obligation_ids": {"type": "array", "items": {"type": "string", "minLength": 1}}, "evidence_id": {"type": "string", "minLength": 1},
    "tolerance_id": {"type": ["string", "null"]}, "approved_change_id": {"type": ["string", "null"]},
    "decision_origin": {"enum": ["DETERMINISTIC_ORACLE", "HUMAN_REVIEW", "AGENT"]}, "flaky": {"type": "boolean"}, "source_target_trace_linked": {"type": "boolean"}
  },
  "allOf": [
    {"if": {"properties": {"status": {"const": "WITHIN_TOLERANCE"}}}, "then": {"required": ["tolerance_id"], "properties": {"tolerance_id": {"type": "string", "minLength": 1}}}},
    {"if": {"properties": {"status": {"const": "APPROVED_CHANGE"}}}, "then": {"required": ["approved_change_id"], "properties": {"approved_change_id": {"type": "string", "minLength": 1}}}}
  ],
  "additionalProperties": false
}
