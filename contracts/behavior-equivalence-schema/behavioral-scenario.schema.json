{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elmos.io/contracts/behavior-equivalence/behavioral-scenario.schema.json",
  "title": "Behavioral differential scenario",
  "type": "object",
  "required": ["scenario_id", "module_id", "category", "criticality", "required", "expected_observations", "required_oracle_ids", "origin", "initial_state_hash", "external_recording_id", "clock_id"],
  "properties": {
    "scenario_id": {"type": "string", "minLength": 1},
    "module_id": {"type": "string", "minLength": 1},
    "category": {"enum": ["HTTP", "MESSAGE", "DATABASE", "FILE", "FUNCTION", "JOB", "PROPERTY", "METAMORPHIC", "CONCURRENCY", "TIME_BOUNDARY", "FAILURE_PATH"]},
    "criticality": {"enum": ["LOW", "MEDIUM", "HIGH", "CRITICAL"]},
    "required": {"type": "boolean"},
    "security_sensitive": {"type": "boolean"},
    "money_sensitive": {"type": "boolean"},
    "transaction_sensitive": {"type": "boolean"},
    "expected_observations": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "required_oracle_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "obligation_ids": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "origin": {"type": "string", "minLength": 1},
    "initial_state_hash": {"type": "string", "pattern": "^[A-Fa-f0-9]{64}$"},
    "external_recording_id": {"type": "string", "minLength": 1},
    "clock_id": {"type": "string", "minLength": 1},
    "random_seed": {"type": ["integer", "null"]},
    "source_target_trace_ref": {"type": ["string", "null"]}
  },
  "additionalProperties": false
}
