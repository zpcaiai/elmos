{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elmos.io/contracts/cdc-status.v1",
  "title": "ELMOS CDC Status",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "organizationId", "streamId", "provider", "offsetType", "sourcePosition", "appliedPosition", "offsetRecoverable", "openTransactions", "status", "evidenceRefs"],
  "properties": {
    "schemaVersion": { "const": "1.0" },
    "organizationId": { "type": "string", "minLength": 1 },
    "streamId": { "type": "string", "minLength": 1 },
    "provider": { "type": "string", "minLength": 1 },
    "offsetType": { "enum": ["ORACLE_SCN", "SQL_SERVER_LSN", "MYSQL_BINLOG", "MYSQL_GTID", "POSTGRESQL_LSN", "VENDOR_CHECKPOINT"] },
    "sourcePosition": { "type": "string", "minLength": 1 },
    "appliedPosition": { "type": "string", "minLength": 1 },
    "offsetRecoverable": { "type": "boolean" },
    "openTransactions": { "type": "integer", "minimum": 0 },
    "timeLagSeconds": { "type": "number", "minimum": 0 },
    "recordLag": { "type": "integer", "minimum": 0 },
    "status": { "enum": ["STARTING", "SNAPSHOTTING", "STREAMING", "CAUGHT_UP", "LAGGING", "FAILED", "STOPPED"] },
    "evidenceRefs": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }
  }
}
