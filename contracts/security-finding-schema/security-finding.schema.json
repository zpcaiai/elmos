{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "elmos.security-finding.v1",
  "type": "object",
  "required": ["findingId", "assetId", "category", "severity", "confidence", "status", "evidenceRefs"],
  "properties": {
    "findingId": {"type": "string"}, "assetId": {"type": "string"}, "category": {"type": "string"},
    "severity": {"enum": ["INFO", "LOW", "MEDIUM", "HIGH", "CRITICAL"]},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "status": {"type": "string"}, "sourceTool": {"type": "string"}, "sourceRule": {"type": "string"},
    "evidenceRefs": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": false
}
