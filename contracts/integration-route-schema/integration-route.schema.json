{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elmos.dev/schemas/integration-route.v1.json",
  "title": "Canonical Integration Route",
  "type": "object",
  "required": ["schemaVersion", "routeId", "sourceEndpointId", "steps", "targetEndpointIds", "stateful", "deliverySemantics"],
  "properties": {
    "schemaVersion": {"const": "1.0"},
    "routeId": {"type": "string", "minLength": 1},
    "sourceEndpointId": {"type": "string", "minLength": 1},
    "steps": {"type": "array", "minItems": 1, "items": {"type": "object", "required": ["kind", "sourceRef"], "properties": {"kind": {"enum": ["SOURCE", "DECODE", "AUTHENTICATE", "AUTHORIZE", "VALIDATE", "TRANSFORM", "ENRICH", "FILTER", "ROUTE", "SPLIT", "AGGREGATE", "INVOKE", "PUBLISH", "PERSIST", "RETRY", "COMPENSATE", "SINK"]}, "sourceRef": {"type": "string"}, "businessLogic": {"type": "boolean"}}, "additionalProperties": true}},
    "targetEndpointIds": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "stateful": {"type": "boolean"},
    "deliverySemantics": {"type": "string"},
    "vendorExtensions": {"type": "array", "items": {"type": "object"}},
    "evidenceRefs": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": false
}
