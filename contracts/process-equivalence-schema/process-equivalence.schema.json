{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.elmos.local/suite-process-equivalence/v1",
  "title": "Suite Process Equivalence Result",
  "type": "object",
  "required": ["schemaVersion", "scenarioId", "sourceResult", "targetResult", "status", "financialStatus", "inventoryStatus", "securityStatus", "evidenceRefs"],
  "properties": {
    "schemaVersion": {"const": "1.0"},
    "scenarioId": {"type": "string", "minLength": 1},
    "sourceResult": {"type": "object"},
    "targetResult": {"type": "object"},
    "status": {"enum": ["EXACT", "BUSINESS_EQUIVALENT", "STANDARDIZED_APPROVED", "EXPECTED_DIFFERENCE", "REGRESSION", "INCONCLUSIVE"]},
    "financialStatus": {"enum": ["PASS", "FAIL", "INCONCLUSIVE", "NOT_APPLICABLE"]},
    "inventoryStatus": {"enum": ["PASS", "FAIL", "INCONCLUSIVE", "NOT_APPLICABLE"]},
    "securityStatus": {"enum": ["PASS", "FAIL", "INCONCLUSIVE"]},
    "standardizationApprovalRef": {"type": "string"},
    "evidenceRefs": {"type": "array", "minItems": 1, "items": {"type": "string"}}
  },
  "additionalProperties": false
}
