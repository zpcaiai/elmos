{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.elmos.io/frontend/client-version-compatibility.v1.schema.json",
  "title": "Client version compatibility",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "organizationId", "clientId", "clientVersion", "platform", "bffVersion", "backendVersion", "contractVersion", "status", "evidenceRefs"],
  "properties": {
    "schemaVersion": {"const": "1.0"},
    "organizationId": {"type": "string", "minLength": 1},
    "clientId": {"type": "string", "minLength": 1},
    "clientVersion": {"type": "string", "minLength": 1},
    "platform": {"enum": ["WEB", "DESKTOP", "ANDROID", "IOS"]},
    "bffVersion": {"type": "string", "minLength": 1},
    "backendVersion": {"type": "string", "minLength": 1},
    "contractVersion": {"type": "string", "minLength": 1},
    "status": {"enum": ["SUPPORTED", "SUPPORTED_WITH_ADAPTER", "DEPRECATED", "BLOCKED", "UNKNOWN"]},
    "expiresAt": {"type": "string", "format": "date-time"},
    "evidenceRefs": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}, "uniqueItems": true}
  }
}
