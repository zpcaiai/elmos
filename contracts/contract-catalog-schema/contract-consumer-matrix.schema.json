{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.elmos.dev/composite/contract-consumer-matrix/1.0.0",
  "title": "ELMOS Cross-language Contract Consumer Matrix",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "organizationId", "contractId", "contractType", "producerId", "producerVersion", "consumers", "overallCompatibility", "evidenceRefs"],
  "properties": {
    "schemaVersion": { "const": "1.0" },
    "organizationId": { "type": "string", "minLength": 1 },
    "contractId": { "type": "string", "minLength": 1 },
    "contractType": { "enum": ["HTTP_OPENAPI", "GRPC_PROTOBUF", "SOAP_WSDL", "ASYNCAPI", "JSON_SCHEMA", "AVRO", "PROTOBUF_MESSAGE", "DATABASE_SCHEMA", "FILE_SCHEMA", "MODEL_SIGNATURE", "CUSTOM_BINARY"] },
    "producerId": { "type": "string", "minLength": 1 },
    "producerVersion": { "type": "string", "minLength": 1 },
    "consumers": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["consumerId", "language", "currentVersion", "targetVersion", "compatibility", "external", "evidenceRefs"],
        "properties": {
          "consumerId": { "type": "string", "minLength": 1 },
          "language": { "enum": ["JAVA", "DOTNET", "PYTHON", "UNKNOWN"] },
          "currentVersion": { "type": "string", "minLength": 1 },
          "targetVersion": { "type": "string", "minLength": 1 },
          "compatibility": { "enum": ["BACKWARD", "FORWARD", "FULL", "BREAKING", "UNKNOWN"] },
          "external": { "type": "boolean" },
          "evidenceRefs": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "overallCompatibility": { "enum": ["BACKWARD", "FORWARD", "FULL", "BREAKING", "UNKNOWN"] },
    "blockers": { "type": "array", "uniqueItems": true, "items": { "type": "string" } },
    "evidenceRefs": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string" } }
  }
}
