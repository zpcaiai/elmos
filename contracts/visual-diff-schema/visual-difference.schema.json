{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.elmos.io/frontend/visual-difference.v1.schema.json",
  "title": "Visual difference",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "organizationId", "scenarioId", "baselineRef", "actualRef", "environmentHash", "differenceRatio", "status", "evidenceRefs"],
  "properties": {
    "schemaVersion": {"const": "1.0"},
    "organizationId": {"type": "string", "minLength": 1},
    "scenarioId": {"type": "string", "minLength": 1},
    "baselineRef": {"type": "string", "minLength": 1},
    "actualRef": {"type": "string", "minLength": 1},
    "environmentHash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "differenceRatio": {"type": "number", "minimum": 0, "maximum": 1},
    "status": {"enum": ["VISUAL_MATCH", "WITHIN_THRESHOLD", "EXPECTED_APPROVED_CHANGE", "REGRESSION", "UNSTABLE_BASELINE", "NOT_COMPARABLE"]},
    "approvedBy": {"type": "string", "minLength": 1},
    "evidenceRefs": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}, "uniqueItems": true}
  },
  "allOf": [{"if": {"properties": {"status": {"const": "EXPECTED_APPROVED_CHANGE"}}}, "then": {"required": ["approvedBy"]}}]
}
