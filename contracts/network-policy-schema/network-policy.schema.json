{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "elmos.network-policy.v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["policyId", "version", "defaultAction", "allowedHosts"],
  "properties": {
    "policyId": {"type": "string", "minLength": 1},
    "version": {"type": "integer", "minimum": 1},
    "defaultAction": {"const": "DENY"},
    "allowedHosts": {"type": "array", "uniqueItems": true, "items": {"type": "string", "format": "hostname"}},
    "expiresAt": {"type": ["string", "null"], "format": "date-time"}
  }
}
