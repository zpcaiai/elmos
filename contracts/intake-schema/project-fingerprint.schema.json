{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "elmos.polyglot.project-fingerprint.v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "snapshotId", "primaryLanguage", "languages", "buildSystems", "frameworks", "modules", "unresolved"],
  "properties": {
    "schemaVersion": {"const": "1.0"}, "snapshotId": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "primaryLanguage": {"enum": ["JAVA", "PYTHON", "CSHARP", "JAVASCRIPT", "TYPESCRIPT", "OTHER"]},
    "languages": {"type": "array", "items": {"type": "object", "required": ["language", "fileCount", "logicalLines", "confidence", "evidence"]}},
    "buildSystems": {"type": "array", "items": {"type": "string"}}, "frameworks": {"type": "array", "items": {"type": "object"}},
    "modules": {"type": "array", "items": {"type": "object"}}, "unresolved": {"type": "array", "items": {"type": "string"}}
  }
}
