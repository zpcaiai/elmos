{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elmos.dev/schemas/psp/v1/provenance.schema.json",
  "title": "PSP v1 Provenance",
  "type": "object",
  "required": ["adapter", "adapterVersion", "provider", "providerVersion", "method", "analysisProfile", "resolution", "confidence", "inputHashes", "observedAt"],
  "properties": {
    "adapter": {"type": "string", "minLength": 1},
    "adapterVersion": {"type": "string", "minLength": 1},
    "provider": {"type": "string", "minLength": 1},
    "providerVersion": {"type": "string", "minLength": 1},
    "method": {"type": "string", "minLength": 1},
    "analysisProfile": {"type": "string", "minLength": 1},
    "resolution": {"type": "string", "minLength": 1},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "inputHashes": {"type": "array", "items": {"type": "string"}},
    "observedAt": {"type": "string", "format": "date-time"}
  },
  "additionalProperties": false
}
