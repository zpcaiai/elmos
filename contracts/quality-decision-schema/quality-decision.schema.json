{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "elmos.quality-decision.v1",
  "type": "object",
  "required": ["scopeId", "sourceCommit", "decision", "confidence", "evidenceManifestHash", "evidenceRefs", "workerModifiedGate"],
  "properties": {
    "scopeId": {"type": "string"}, "sourceCommit": {"type": "string"},
    "decision": {"enum": ["PASS", "PASS_WITH_WARNINGS", "CONDITIONAL_PASS", "FAIL", "NOT_RUN", "INCONCLUSIVE", "STALE"]},
    "confidence": {"enum": ["HIGH", "MODERATE", "LOW", "INSUFFICIENT", "UNKNOWN"]},
    "evidenceManifestHash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "conditions": {"type": "array"}, "blockers": {"type": "array"}, "unknowns": {"type": "array"},
    "evidenceRefs": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "workerModifiedGate": {"const": false}
  },
  "additionalProperties": false
}
