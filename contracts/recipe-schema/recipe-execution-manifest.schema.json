{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.elmos.dev/recipe-execution-manifest.schema.json",
  "title": "RecipeExecutionManifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "manifestId",
    "sourceSnapshotId",
    "sourceCommit",
    "recipes",
    "runtime",
    "policyHash",
    "manifestHash"
  ],
  "properties": {
    "schemaVersion": {
      "const": "1.0"
    },
    "manifestId": {
      "type": "string",
      "minLength": 1
    },
    "sourceSnapshotId": {
      "type": "string",
      "minLength": 1
    },
    "sourceCommit": {
      "type": "string",
      "minLength": 1
    },
    "recipes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object"
      }
    },
    "runtime": {
      "type": "object"
    },
    "policyHash": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "manifestHash": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    }
  }
}

