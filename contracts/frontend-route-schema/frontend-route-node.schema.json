{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.elmos.io/frontend/frontend-route-node.v1.schema.json",
  "title": "Frontend route node",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "organizationId", "snapshotId", "routeId", "applicationId", "path", "routeType", "componentIds", "requiredPermissions", "confidence", "evidenceRefs"],
  "properties": {
    "schemaVersion": {"const": "1.0"},
    "organizationId": {"type": "string", "minLength": 1},
    "snapshotId": {"type": "string", "minLength": 1},
    "routeId": {"type": "string", "minLength": 1},
    "applicationId": {"type": "string", "minLength": 1},
    "path": {"type": "string", "pattern": "^/"},
    "routeType": {"enum": ["STATIC", "PARAMETERIZED", "DYNAMIC", "DEEP_LINK", "SERVER_RENDERED"]},
    "componentIds": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "requiredPermissions": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "evidenceRefs": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}, "uniqueItems": true}
  }
}
