{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elmos.dev/contracts/ecosystem-growth/north-star.schema.json",
  "title": "North Star Metric Definition",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "metric_id",
    "definition",
    "grain",
    "numerator",
    "denominator",
    "exclusions",
    "owner",
    "driver_metric_ids",
    "guardrail_metric_ids",
    "customer_value_bound",
    "quality_gate_required",
    "definition_version"
  ],
  "properties": {
    "metric_id": { "const": "monthly-verified-migration-value" },
    "definition": { "type": "string", "minLength": 1 },
    "grain": { "type": "string", "minLength": 1 },
    "numerator": { "type": "string", "minLength": 1 },
    "denominator": { "type": ["string", "null"] },
    "exclusions": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "owner": { "type": "string", "minLength": 1 },
    "driver_metric_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "guardrail_metric_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "customer_value_bound": { "const": true },
    "quality_gate_required": { "const": true },
    "definition_version": { "type": "string", "minLength": 1 }
  }
}
