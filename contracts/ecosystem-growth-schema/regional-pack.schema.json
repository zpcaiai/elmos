{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elmos.dev/contracts/ecosystem-growth/regional-pack.schema.json",
  "title": "Regional Pack",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "pack_id",
    "region",
    "market_priority_ref",
    "playbook_version",
    "supported_locales",
    "partner_refs",
    "poc_factory_ref",
    "solution_assets",
    "legal_approval_ref",
    "brand_approval_ref",
    "status"
  ],
  "properties": {
    "pack_id": {
      "type": "string",
      "minLength": 1
    },
    "region": {
      "type": "string",
      "minLength": 2
    },
    "market_priority_ref": {
      "type": "string",
      "minLength": 1
    },
    "playbook_version": {
      "type": "string",
      "minLength": 1
    },
    "supported_locales": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string"
      }
    },
    "partner_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "poc_factory_ref": {
      "type": "string",
      "minLength": 1
    },
    "solution_assets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "legal_approval_ref": {
      "type": "string",
      "minLength": 1
    },
    "brand_approval_ref": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": [
        "DRAFT",
        "REVIEW",
        "APPROVED",
        "SUSPENDED",
        "RETIRED"
      ]
    }
  }
}

