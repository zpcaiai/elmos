{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elmos.dev/contracts/ecosystem-growth/developer-extension-manifest.schema.json",
  "title": "Developer Extension Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "extension_id",
    "version",
    "runtime_api_version",
    "permissions",
    "supported_inputs",
    "outputs",
    "network_policy",
    "signature_status"
  ],
  "properties": {
    "extension_id": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "runtime_api_version": {
      "type": "string",
      "minLength": 1
    },
    "permissions": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string"
      }
    },
    "supported_inputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "outputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "network_policy": {
      "enum": [
        "DENY_ALL",
        "ALLOWLIST"
      ]
    },
    "signature_status": {
      "enum": [
        "UNSIGNED_COMMUNITY",
        "SIGNED",
        "REVOKED"
      ]
    }
  }
}

