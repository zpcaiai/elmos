{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elmos.dev/contracts/ecosystem-growth/growth-program.schema.json",
  "title": "Growth Program",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "program_id",
    "product_version",
    "target_segments",
    "target_regions",
    "product_motions",
    "primary_goals",
    "north_star_metric_id",
    "budget_currency",
    "budget_amount",
    "policy_version"
  ],
  "properties": {
    "program_id": { "type": "string", "minLength": 1 },
    "product_version": { "type": "string", "minLength": 1 },
    "target_segments": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "target_regions": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 2 }
    },
    "product_motions": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "enum": ["self-service", "sales-assisted", "partner-led"]
      }
    },
    "primary_goals": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "enum": ["acquisition", "activation", "adoption", "retention", "expansion", "advocacy", "ecosystem"]
      }
    },
    "north_star_metric_id": { "type": "string", "minLength": 1 },
    "budget_currency": { "type": "string", "pattern": "^[A-Z]{3}$" },
    "budget_amount": { "type": "number", "minimum": 0 },
    "policy_version": { "type": "string", "minLength": 1 }
  }
}
