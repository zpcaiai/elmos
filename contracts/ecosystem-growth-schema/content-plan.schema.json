{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elmos.dev/contracts/ecosystem-growth/content-plan.schema.json",
  "title": "Content Plan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "content_id",
    "pillar",
    "funnel_stage",
    "audiences",
    "owner",
    "technical_review_status",
    "security_review_status",
    "locale",
    "review_due_at"
  ],
  "properties": {
    "content_id": {
      "type": "string",
      "minLength": 1
    },
    "pillar": {
      "type": "string",
      "minLength": 1
    },
    "funnel_stage": {
      "enum": [
        "AWARENESS",
        "EDUCATION",
        "EVALUATION",
        "TECHNICAL_VALIDATION",
        "COMMERCIAL_DECISION",
        "ADOPTION",
        "ADVOCACY"
      ]
    },
    "audiences": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string"
      }
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "technical_review_status": {
      "enum": [
        "NOT_RUN",
        "PENDING",
        "PASSED",
        "FAILED"
      ]
    },
    "security_review_status": {
      "enum": [
        "NOT_APPLICABLE",
        "NOT_RUN",
        "PENDING",
        "PASSED",
        "FAILED"
      ]
    },
    "locale": {
      "type": "string",
      "minLength": 2
    },
    "review_due_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}

