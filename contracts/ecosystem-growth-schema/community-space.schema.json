{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elmos.dev/contracts/ecosystem-growth/community-space.schema.json",
  "title": "Community Space",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "space_id",
    "visibility",
    "posting_roles",
    "moderation_policy",
    "data_classification",
    "region",
    "appeal_policy"
  ],
  "properties": {
    "space_id": {
      "type": "string",
      "minLength": 1
    },
    "visibility": {
      "enum": [
        "public",
        "tenant",
        "invite-only"
      ]
    },
    "posting_roles": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string"
      }
    },
    "moderation_policy": {
      "type": "string",
      "minLength": 1
    },
    "data_classification": {
      "enum": [
        "PUBLIC",
        "INTERNAL",
        "CONFIDENTIAL",
        "RESTRICTED"
      ]
    },
    "region": {
      "type": "string",
      "minLength": 2
    },
    "appeal_policy": {
      "type": "string",
      "minLength": 1
    }
  }
}

