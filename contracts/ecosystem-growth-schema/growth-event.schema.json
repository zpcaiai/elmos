{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elmos.dev/contracts/ecosystem-growth/growth-event.schema.json",
  "title": "Growth Event",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event_id",
    "occurred_at",
    "actor",
    "event_name",
    "context",
    "properties",
    "schema_version",
    "idempotency_key"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "minLength": 1
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time"
    },
    "actor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "account_id",
        "tenant_id"
      ],
      "properties": {
        "anonymous_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "user_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "account_id": {
          "type": "string",
          "minLength": 1
        },
        "tenant_id": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "event_name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(\\.[a-z][a-z0-9]*)+$"
    },
    "context": {
      "type": "object"
    },
    "properties": {
      "type": "object"
    },
    "schema_version": {
      "type": "integer",
      "minimum": 1
    },
    "idempotency_key": {
      "type": "string",
      "minLength": 1
    }
  }
}

