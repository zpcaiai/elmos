{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elmos.dev/contracts/ecosystem-growth/marketplace-installation.schema.json",
  "title": "Marketplace Installation",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "installation_id",
    "organization_id",
    "asset_id",
    "asset_version",
    "deployment_mode",
    "status",
    "rollback_version",
    "evidence_refs"
  ],
  "properties": {
    "installation_id": {
      "type": "string",
      "minLength": 1
    },
    "organization_id": {
      "type": "string",
      "minLength": 1
    },
    "asset_id": {
      "type": "string",
      "minLength": 1
    },
    "asset_version": {
      "type": "string",
      "minLength": 1
    },
    "deployment_mode": {
      "enum": [
        "saas",
        "self-hosted",
        "offline"
      ]
    },
    "status": {
      "enum": [
        "PLANNED",
        "APPROVED",
        "INSTALLED",
        "FAILED",
        "ROLLED_BACK",
        "REMOVED"
      ]
    },
    "rollback_version": {
      "type": [
        "string",
        "null"
      ]
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    }
  }
}

