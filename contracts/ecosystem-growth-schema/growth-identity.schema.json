{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elmos.dev/contracts/ecosystem-growth/growth-identity.schema.json",
  "title": "Growth Identity",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "identity_id",
    "account_id",
    "tenant_id",
    "organization_ids",
    "source",
    "merge_status",
    "consent_status",
    "schema_version"
  ],
  "properties": {
    "identity_id": {
      "type": "string",
      "minLength": 1
    },
    "anonymous_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "user_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "account_id": {
      "type": "string",
      "minLength": 1
    },
    "tenant_id": {
      "type": "string",
      "minLength": 1
    },
    "organization_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string"
      }
    },
    "source": {
      "type": "string",
      "minLength": 1
    },
    "merge_status": {
      "enum": [
        "UNMERGED",
        "CONFIRMED",
        "REJECTED",
        "ANONYMIZED"
      ]
    },
    "consent_status": {
      "enum": [
        "GRANTED",
        "DENIED",
        "NOT_REQUIRED",
        "WITHDRAWN"
      ]
    },
    "schema_version": {
      "type": "integer",
      "minimum": 1
    }
  }
}

