{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elmos.dev/schemas/trading-partner-agreement.v1.json",
  "title": "Trading Partner Agreement",
  "type": "object",
  "required": ["schemaVersion", "agreementId", "partnerId", "protocol", "documentTypes", "status", "transportAckPolicy", "businessAckPolicy"],
  "properties": {
    "schemaVersion": {"const": "1.0"},
    "agreementId": {"type": "string"},
    "partnerId": {"type": "string"},
    "protocol": {"enum": ["AS2", "SFTP", "FTPS", "HTTPS", "OFTP", "VAN", "EMAIL", "CUSTOM"]},
    "documentTypes": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "certificateRefs": {"type": "array", "items": {"type": "string"}},
    "certificateOverlapWindow": {"type": "boolean"},
    "transportAckPolicy": {"type": "string"},
    "businessAckPolicy": {"type": "string"},
    "status": {"enum": ["DRAFT", "TESTING", "CERTIFIED", "ACTIVE", "SUNSET", "RETIRED"]}
  },
  "additionalProperties": false
}
