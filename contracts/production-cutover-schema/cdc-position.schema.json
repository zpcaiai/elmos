{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elmos.dev/contracts/production-cutover/cdc-position.schema.json",
  "title": "CDC Position and Health",
  "type": "object",
  "additionalProperties": false,
  "required": ["stream_id", "asset_id", "source_position", "target_position", "lag_seconds", "healthy", "insert_coverage", "update_coverage", "delete_coverage", "duplicates_handled", "out_of_order_handled", "captured_at", "evidence_refs"],
  "properties": {
    "stream_id": {"type": "string", "minLength": 1},
    "asset_id": {"type": "string", "minLength": 1},
    "source_position": {"type": "string", "minLength": 1},
    "target_position": {"type": "string", "minLength": 1},
    "lag_seconds": {"type": "integer", "minimum": 0},
    "healthy": {"type": "boolean"},
    "insert_coverage": {"type": "number", "minimum": 0, "maximum": 1},
    "update_coverage": {"type": "number", "minimum": 0, "maximum": 1},
    "delete_coverage": {"type": "number", "minimum": 0, "maximum": 1},
    "duplicates_handled": {"type": "boolean"},
    "out_of_order_handled": {"type": "boolean"},
    "captured_at": {"type": "string", "format": "date-time"},
    "evidence_refs": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}
  }
}
