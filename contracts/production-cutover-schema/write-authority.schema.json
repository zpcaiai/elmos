{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elmos.dev/contracts/production-cutover/write-authority.schema.json",
  "title": "Aggregate Read and Write Authority",
  "type": "object",
  "additionalProperties": false,
  "required": ["aggregate_id", "segment_id", "phase", "primary_writer", "primary_reader", "fallback_reader", "stable_routing_key", "version", "all_entrypoints_compliant", "dual_primary_detected", "atomically_published", "client_can_override", "evidence_refs"],
  "properties": {
    "aggregate_id": {"type": "string", "minLength": 1},
    "segment_id": {"type": "string", "minLength": 1},
    "phase": {"$ref": "cutover-state-machine.schema.json#/$defs/phaseId"},
    "primary_writer": {"enum": ["SOURCE", "TARGET"]},
    "primary_reader": {"enum": ["SOURCE", "TARGET"]},
    "fallback_reader": {"type": ["string", "null"], "enum": ["SOURCE", "TARGET", null]},
    "stable_routing_key": {"type": "string", "minLength": 1},
    "version": {"type": "integer", "minimum": 1},
    "all_entrypoints_compliant": {"const": true},
    "dual_primary_detected": {"const": false},
    "atomically_published": {"const": true},
    "client_can_override": {"const": false},
    "evidence_refs": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}
  }
}
