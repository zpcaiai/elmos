{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elmos.dev/contracts/production-cutover/data-asset.schema.json",
  "title": "Production Data Asset",
  "type": "object",
  "additionalProperties": false,
  "required": ["asset_id", "category", "owner", "source_location", "target_location", "estimated_records", "estimated_bytes", "change_rate_per_second", "sensitivity", "migration_strategy", "retention_policy", "legal_hold", "mapping_coverage", "irreversible_transformation", "lossy_transformation_approved", "evidence_refs"],
  "properties": {
    "asset_id": {"type": "string", "minLength": 1},
    "category": {"enum": ["AUTHORITATIVE", "DERIVED", "REBUILDABLE", "EPHEMERAL", "AUDIT", "REGULATED", "ARCHIVAL", "OBSOLETE", "UNKNOWN"]},
    "owner": {"type": "string", "minLength": 1},
    "source_location": {"type": "string", "minLength": 1},
    "target_location": {"type": "string", "minLength": 1},
    "estimated_records": {"type": "integer", "minimum": 0},
    "estimated_bytes": {"type": "integer", "minimum": 0},
    "change_rate_per_second": {"type": "number", "minimum": 0},
    "sensitivity": {"type": "string", "minLength": 1},
    "migration_strategy": {"type": "string", "minLength": 1},
    "retention_policy": {"type": "string", "minLength": 1},
    "legal_hold": {"type": "boolean"},
    "mapping_coverage": {"type": "number", "minimum": 0, "maximum": 1},
    "irreversible_transformation": {"type": "boolean"},
    "lossy_transformation_approved": {"type": "boolean"},
    "evidence_refs": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}
  }
}
