{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elmos.dev/contracts/production-cutover/migration-wave.schema.json",
  "title": "Migration Wave",
  "type": "object",
  "additionalProperties": false,
  "required": ["wave_id", "order", "risk_tier", "business_owner", "stable_segmentation", "independently_reversible", "segment_keys", "entry_gate_refs", "exit_gate_refs", "evidence_refs"],
  "properties": {
    "wave_id": {"type": "string", "minLength": 1},
    "order": {"type": "integer", "minimum": 1},
    "risk_tier": {"type": "integer", "minimum": 0, "maximum": 4},
    "business_owner": {"type": "string", "minLength": 1},
    "stable_segmentation": {"const": true},
    "independently_reversible": {"const": true},
    "segment_keys": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "entry_gate_refs": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "exit_gate_refs": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "evidence_refs": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}
  }
}
