{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elmos.dev/contracts/production-cutover/cutover-run-manifest.schema.json",
  "title": "Batch 11 Cutover Run Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["batch", "cutover_run_id", "migration_id", "source_artifact", "target_artifact", "batch10_eligible", "current_phase", "artifact_workspace", "source_repository_path", "target_repository_path", "waves", "authorities", "data_assets", "approvals", "policy", "observed_at", "production_change_executed"],
  "properties": {
    "batch": {"const": 11},
    "cutover_run_id": {"type": "string", "minLength": 1},
    "migration_id": {"type": "string", "minLength": 1},
    "source_artifact": {"$ref": "#/$defs/sourceArtifact"},
    "target_artifact": {"$ref": "#/$defs/targetArtifact"},
    "batch10_eligible": {"const": true},
    "current_phase": {"$ref": "cutover-state-machine.schema.json#/$defs/phaseId"},
    "artifact_workspace": {"type": "string", "minLength": 1},
    "source_repository_path": {"type": "string", "minLength": 1},
    "target_repository_path": {"type": "string", "minLength": 1},
    "waves": {"type": "array", "minItems": 1, "items": {"type": "object"}},
    "authorities": {"type": "array", "minItems": 1, "items": {"type": "object"}},
    "data_assets": {"type": "array", "minItems": 1, "items": {"type": "object"}},
    "approvals": {"type": "array", "items": {"type": "object"}},
    "policy": {"type": "object"},
    "observed_at": {"type": "string", "format": "date-time"},
    "production_change_executed": {"const": false},
    "wave_refs": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "evidence_refs": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}
  },
  "$defs": {
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifact_id", "artifact_digest", "snapshot_id", "immutable", "role"],
      "properties": {
        "artifact_id": {"type": "string", "minLength": 1},
        "artifact_digest": {"type": "string", "pattern": "^[A-Fa-f0-9]{64}$"},
        "snapshot_id": {"type": "string", "minLength": 1},
        "immutable": {"const": true},
        "role": {"enum": ["SOURCE", "TARGET"]},
        "batch10_gate": {"type": "string"},
        "eligible_for_progressive_delivery": {"type": "boolean"},
        "evidence_refs": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}
      }
    },
    "sourceArtifact": {
      "allOf": [
        {"$ref": "#/$defs/artifact"},
        {"properties": {"role": {"const": "SOURCE"}}}
      ]
    },
    "targetArtifact": {
      "allOf": [
        {"$ref": "#/$defs/artifact"},
        {
          "required": ["batch10_gate", "eligible_for_progressive_delivery"],
          "properties": {
            "role": {"const": "TARGET"},
            "batch10_gate": {"enum": ["P_E", "P_F"]},
            "eligible_for_progressive_delivery": {"const": true}
          }
        }
      ]
    }
  }
}
