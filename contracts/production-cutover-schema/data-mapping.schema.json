{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elmos.dev/contracts/production-cutover/data-mapping.schema.json",
  "title": "Data Mapping and Transformation Rule",
  "type": "object",
  "additionalProperties": false,
  "required": ["mapping_id", "asset_id", "source_path", "target_path", "transformation", "reversible", "null_semantics_verified", "identifier_mapping_verified", "evidence_refs"],
  "properties": {
    "mapping_id": {"type": "string", "minLength": 1},
    "asset_id": {"type": "string", "minLength": 1},
    "source_path": {"type": "string", "minLength": 1},
    "target_path": {"type": "string", "minLength": 1},
    "transformation": {"type": "string", "minLength": 1},
    "reversible": {"type": "boolean"},
    "null_semantics_verified": {"type": "boolean"},
    "identifier_mapping_verified": {"type": "boolean"},
    "lossy": {"type": "boolean"},
    "loss_approval_ref": {"type": "string"},
    "evidence_refs": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}
  },
  "allOf": [
    {
      "if": {"properties": {"lossy": {"const": true}}, "required": ["lossy"]},
      "then": {"required": ["loss_approval_ref"], "properties": {"loss_approval_ref": {"minLength": 1}}}
    }
  ]
}
