{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.elmos.dev/composite/shadow-differential-result/1.0.0",
  "title": "ELMOS Shadow Differential Result",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "experimentId", "requestId", "tenantId", "status", "primaryResultUnaffected", "canEnterCanary", "differences", "evidenceRefs"],
  "properties": {
    "schemaVersion": { "const": "1.0" },
    "experimentId": { "type": "string", "minLength": 1 },
    "requestId": { "type": "string", "minLength": 1 },
    "tenantId": { "type": "string", "minLength": 1 },
    "status": { "enum": ["EXACT_MATCH", "SEMANTIC_MATCH", "WITHIN_TOLERANCE", "EXPECTED_DIFFERENCE", "REGRESSION", "NOT_COMPARABLE", "SHADOW_EXECUTION_FAILED"] },
    "primaryResultUnaffected": { "type": "boolean" },
    "canEnterCanary": { "type": "boolean" },
    "differences": { "type": "array", "items": { "type": "string" } },
    "evidenceRefs": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string" } }
  }
}
