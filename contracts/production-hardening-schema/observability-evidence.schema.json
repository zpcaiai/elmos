{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elmos.io/contracts/production-hardening/observability-evidence.schema.json",
  "title": "Service observability and operability evidence",
  "type": "object",
  "required": [
    "service_id",
    "artifact_id",
    "status",
    "critical_sli_coverage",
    "alert_coverage",
    "runbook_coverage",
    "trace_coverage",
    "slo_calculable",
    "critical_alerts_tested",
    "critical_runbooks_validated",
    "correlation_passed",
    "production_resource_accessed",
    "secret_material_observed",
    "authority_id",
    "evidence_refs"
  ],
  "properties": {
    "service_id": {
      "type": "string",
      "minLength": 1
    },
    "artifact_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "$ref": "#/$defs/status"
    },
    "critical_sli_coverage": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "alert_coverage": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "runbook_coverage": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "trace_coverage": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "slo_calculable": {
      "type": "boolean"
    },
    "critical_alerts_tested": {
      "type": "boolean"
    },
    "critical_runbooks_validated": {
      "type": "boolean"
    },
    "correlation_passed": {
      "type": "boolean"
    },
    "telemetry_overhead_within_budget": {
      "type": "boolean"
    },
    "sensitive_telemetry_leaks": {
      "type": "integer",
      "minimum": 0
    },
    "unbounded_metric_labels": {
      "type": "integer",
      "minimum": 0
    },
    "production_resource_accessed": {
      "const": false
    },
    "secret_material_observed": {
      "const": false
    },
    "authority_id": {
      "type": "string",
      "minLength": 1
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "status": {
      "enum": [
        "PASSED",
        "FAILED",
        "NOT_RUN",
        "BLOCKED",
        "INCONCLUSIVE",
        "NOT_APPLICABLE"
      ]
    }
  }
}

