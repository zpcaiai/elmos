{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elmos.io/contracts/production-hardening/batch-10-conformance-report.schema.json",
  "title": "Batch 10 conformance and release gate report",
  "type": "object",
  "required": [
    "batch",
    "hardening_run_id",
    "artifact_id",
    "status",
    "services",
    "blockers",
    "eligible_for_progressive_delivery",
    "production_ready",
    "eligible_for_cutover",
    "evaluated_at"
  ],
  "properties": {
    "batch": {
      "const": 10
    },
    "hardening_run_id": {
      "type": "string",
      "minLength": 1
    },
    "artifact_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": [
        "INITIALIZED",
        "PROFILING",
        "PERFORMANCE_TESTING",
        "SECURITY_TESTING",
        "RESILIENCE_TESTING",
        "RECOVERY_TESTING",
        "OBSERVABILITY_TESTING",
        "RELEASE_TESTING",
        "READY_FOR_PROGRESSIVE_DELIVERY",
        "READY_WITH_RESTRICTIONS",
        "BLOCKED",
        "FAILED_SAFELY"
      ]
    },
    "services": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/service"
      }
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "eligible_for_progressive_delivery": {
      "type": "boolean"
    },
    "production_ready": {
      "const": false
    },
    "eligible_for_cutover": {
      "const": false
    },
    "evaluated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "service": {
      "type": "object",
      "required": [
        "service_id",
        "gate",
        "eligible_for_progressive_delivery",
        "production_ready",
        "eligible_for_cutover",
        "blockers",
        "restrictions",
        "metrics",
        "evidence_refs"
      ],
      "properties": {
        "service_id": {
          "type": "string",
          "minLength": 1
        },
        "gate": {
          "enum": [
            "BLOCKED",
            "P_A",
            "P_B",
            "P_C",
            "P_D",
            "P_E",
            "P_F"
          ]
        },
        "eligible_for_progressive_delivery": {
          "type": "boolean"
        },
        "production_ready": {
          "const": false
        },
        "eligible_for_cutover": {
          "const": false
        },
        "blockers": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "restrictions": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "metrics": {
          "type": "object"
        },
        "evidence_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": false
    }
  }
}

