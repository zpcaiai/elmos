{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elmos.io/contracts/production-hardening/release-artifact.schema.json",
  "title": "Release artifact and progressive-delivery evidence",
  "type": "object",
  "required": [
    "service_id",
    "artifact_id",
    "status",
    "artifact_immutable",
    "artifact_signed",
    "signature_verified",
    "provenance_complete",
    "sbom_complete",
    "canary_plan_validated",
    "rollback_plan_validated",
    "progressive_delivery_only",
    "production_deployment_executed",
    "production_resource_accessed",
    "secret_material_observed",
    "authority_id",
    "evidence_refs"
  ],
  "properties": {
    "service_id": {
      "type": "string",
      "minLength": 1
    },
    "artifact_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "$ref": "#/$defs/status"
    },
    "artifact_immutable": {
      "const": true
    },
    "artifact_signed": {
      "type": "boolean"
    },
    "signature_verified": {
      "type": "boolean"
    },
    "provenance_complete": {
      "type": "boolean"
    },
    "reproducible_build_passed": {
      "type": "boolean"
    },
    "sbom_complete": {
      "type": "boolean"
    },
    "canary_plan_validated": {
      "type": "boolean"
    },
    "canary_drill_passed": {
      "type": "boolean"
    },
    "rollback_plan_validated": {
      "type": "boolean"
    },
    "rollback_drill_passed": {
      "type": "boolean"
    },
    "schema_compatibility_passed": {
      "type": "boolean"
    },
    "forward_fix_runbook_validated": {
      "type": "boolean"
    },
    "open_critical_risks": {
      "type": "integer",
      "minimum": 0
    },
    "unapproved_risks": {
      "type": "integer",
      "minimum": 0
    },
    "progressive_delivery_only": {
      "const": true
    },
    "production_deployment_executed": {
      "const": false
    },
    "production_resource_accessed": {
      "const": false
    },
    "secret_material_observed": {
      "const": false
    },
    "authority_id": {
      "type": "string",
      "minLength": 1
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "status": {
      "enum": [
        "PASSED",
        "FAILED",
        "NOT_RUN",
        "BLOCKED",
        "INCONCLUSIVE",
        "NOT_APPLICABLE"
      ]
    }
  }
}

