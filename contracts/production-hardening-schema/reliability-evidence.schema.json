{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elmos.io/contracts/production-hardening/reliability-evidence.schema.json",
  "title": "Service reliability recovery and DR evidence",
  "type": "object",
  "required": [
    "service_id",
    "artifact_id",
    "status",
    "critical_chaos_pass_rate",
    "recovery_scenario_pass_rate",
    "data_corruption_events",
    "unbounded_retries",
    "unbounded_queues",
    "retry_storms",
    "crash_consistency_passed",
    "dependency_recovery_passed",
    "abort_and_kill_switches_verified",
    "production_resource_accessed",
    "destructive_production_chaos",
    "secret_material_observed",
    "authority_id",
    "evidence_refs"
  ],
  "properties": {
    "service_id": {
      "type": "string",
      "minLength": 1
    },
    "artifact_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "$ref": "#/$defs/status"
    },
    "critical_chaos_pass_rate": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "recovery_scenario_pass_rate": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "data_corruption_events": {
      "type": "integer",
      "minimum": 0
    },
    "unbounded_retries": {
      "type": "integer",
      "minimum": 0
    },
    "unbounded_queues": {
      "type": "integer",
      "minimum": 0
    },
    "retry_storms": {
      "type": "integer",
      "minimum": 0
    },
    "crash_consistency_passed": {
      "type": "boolean"
    },
    "dependency_recovery_passed": {
      "type": "boolean"
    },
    "backup_restore_passed": {
      "type": "boolean"
    },
    "pitr_passed": {
      "type": "boolean"
    },
    "rpo_passed": {
      "type": "boolean"
    },
    "rto_passed": {
      "type": "boolean"
    },
    "failover_and_failback_passed": {
      "type": "boolean"
    },
    "abort_and_kill_switches_verified": {
      "type": "boolean"
    },
    "production_resource_accessed": {
      "const": false
    },
    "destructive_production_chaos": {
      "const": false
    },
    "secret_material_observed": {
      "const": false
    },
    "authority_id": {
      "type": "string",
      "minLength": 1
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "status": {
      "enum": [
        "PASSED",
        "FAILED",
        "NOT_RUN",
        "BLOCKED",
        "INCONCLUSIVE",
        "NOT_APPLICABLE"
      ]
    }
  }
}

