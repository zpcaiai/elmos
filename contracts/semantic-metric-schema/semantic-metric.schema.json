{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elmos.io/contracts/semantic-metric.v1",
  "title": "ELMOS Semantic Metric",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "organizationId", "metricId", "name", "domain", "owner", "expression", "grain", "timezone", "version", "effectiveDate"],
  "properties": {
    "schemaVersion": { "const": "1.0" },
    "organizationId": { "type": "string", "minLength": 1 },
    "metricId": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "domain": { "type": "string", "minLength": 1 },
    "owner": { "type": "string", "minLength": 1 },
    "expression": { "type": "string", "minLength": 1 },
    "grain": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "filter": { "type": "string" },
    "timezone": { "type": "string", "minLength": 1 },
    "currency": { "type": "string" },
    "version": { "type": "string", "minLength": 1 },
    "effectiveDate": { "type": "string", "format": "date" }
  }
}
