{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "elmos.container-image-manifest.v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["imageDigest", "baseImageDigest", "architectures", "nonRoot", "readOnlyRootFilesystem", "gracefulShutdown", "sbomRef", "signatureRef", "provenanceRef", "secretInLayer", "status", "evidenceRefs"],
  "properties": {
    "imageDigest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "baseImageDigest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "architectures": {"type": "array", "minItems": 1, "items": {"enum": ["linux/amd64", "linux/arm64", "windows/amd64"]}},
    "nonRoot": {"type": "boolean"},
    "readOnlyRootFilesystem": {"type": "boolean"},
    "gracefulShutdown": {"enum": ["PASS", "FAIL", "NOT_RUN"]},
    "sbomRef": {"type": "string"},
    "signatureRef": {"type": "string"},
    "provenanceRef": {"type": "string"},
    "secretInLayer": {"type": "boolean"},
    "status": {"enum": ["VERIFIED", "BLOCKED", "NOT_RUN"]},
    "evidenceRefs": {"type": "array", "items": {"type": "string"}}
  }
}
