{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elmos.dev/contracts/commercial-loop/quote.schema.json",
  "title": "Commercial Quote Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "quote_id",
    "account_id",
    "opportunity_id",
    "catalog_version",
    "currency",
    "term_start",
    "term_end",
    "line_items",
    "subtotal",
    "discount",
    "total",
    "margin",
    "status",
    "source_system",
    "owner",
    "version",
    "evidence_refs"
  ],
  "properties": {
    "quote_id": {
      "type": "string",
      "minLength": 1
    },
    "account_id": {
      "type": "string",
      "minLength": 1
    },
    "opportunity_id": {
      "type": "string",
      "minLength": 1
    },
    "catalog_version": {
      "type": "string",
      "minLength": 1
    },
    "currency": {
      "type": "string",
      "pattern": "^[A-Z]{3}$"
    },
    "term_start": {
      "type": "string",
      "format": "date"
    },
    "term_end": {
      "type": "string",
      "format": "date"
    },
    "line_items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "sku",
          "quantity",
          "unit_price",
          "scope_ref"
        ],
        "properties": {
          "sku": {
            "type": "string",
            "minLength": 1
          },
          "quantity": {
            "type": "number",
            "exclusiveMinimum": 0
          },
          "unit_price": {
            "type": "number",
            "minimum": 0
          },
          "scope_ref": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "subtotal": {
      "type": "number",
      "minimum": 0
    },
    "discount": {
      "type": "number",
      "minimum": 0
    },
    "total": {
      "type": "number",
      "minimum": 0
    },
    "margin": {
      "type": "number"
    },
    "status": {
      "enum": [
        "DRAFT",
        "REVIEW",
        "APPROVED",
        "REJECTED",
        "EXPIRED",
        "ACCEPTED"
      ]
    },
    "source_system": {
      "type": "string",
      "minLength": 1
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}

