{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elmos.dev/contracts/commercial-loop/lifecycle-record.schema.json",
  "title": "Commercial Customer Lifecycle Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "lifecycle_id",
    "account_id",
    "opportunity_id",
    "tenant_id",
    "stage",
    "owner",
    "entry_criteria_satisfied",
    "exit_criteria_satisfied",
    "next_action",
    "estimated_date",
    "risks",
    "commercial_amount",
    "technical_scope",
    "evidence_refs"
  ],
  "properties": {
    "lifecycle_id": {
      "type": "string",
      "minLength": 1
    },
    "account_id": {
      "type": "string",
      "minLength": 1
    },
    "opportunity_id": {
      "type": "string",
      "minLength": 1
    },
    "tenant_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "stage": {
      "enum": [
        "TARGET_ACCOUNT",
        "QUALIFIED_LEAD",
        "QUALIFIED_OPPORTUNITY",
        "DISCOVERY",
        "TECHNICAL_ASSESSMENT",
        "POC_PROPOSED",
        "POC_RUNNING",
        "POC_ACCEPTED",
        "COMMERCIAL_PROPOSAL",
        "CONTRACTED",
        "ONBOARDING",
        "IMPLEMENTATION",
        "PRODUCTION_MIGRATION",
        "HYPERCARE",
        "CUSTOMER_ACCEPTED",
        "MANAGED_SERVICE",
        "RENEWAL_EXPANSION",
        "DISQUALIFIED",
        "NO_DECISION",
        "POC_FAILED",
        "SECURITY_BLOCKED",
        "BUDGET_BLOCKED",
        "TECHNICAL_BLOCKED",
        "LOST_TO_COMPETITOR",
        "PAUSED",
        "CHURN_RISK",
        "TERMINATED"
      ]
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "entry_criteria_satisfied": {
      "type": "boolean"
    },
    "exit_criteria_satisfied": {
      "type": "boolean"
    },
    "next_action": {
      "type": "string",
      "minLength": 1
    },
    "estimated_date": {
      "type": "string",
      "format": "date-time"
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "commercial_amount": {
      "type": "number",
      "minimum": 0
    },
    "technical_scope": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}

