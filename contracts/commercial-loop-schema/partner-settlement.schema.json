{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elmos.dev/contracts/commercial-loop/partner-settlement.schema.json",
  "title": "Partner Settlement Reconciliation",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "settlement_id",
    "partner_id",
    "period_start",
    "period_end",
    "currency",
    "gross_eligible_revenue",
    "adjustments",
    "revenue_share",
    "net_settlement",
    "formula_version",
    "status",
    "source_system",
    "approved_by",
    "evidence_refs"
  ],
  "properties": {
    "settlement_id": {
      "type": "string",
      "minLength": 1
    },
    "partner_id": {
      "type": "string",
      "minLength": 1
    },
    "period_start": {
      "type": "string",
      "format": "date"
    },
    "period_end": {
      "type": "string",
      "format": "date"
    },
    "currency": {
      "type": "string",
      "pattern": "^[A-Z]{3}$"
    },
    "gross_eligible_revenue": {
      "type": "number",
      "minimum": 0
    },
    "adjustments": {
      "type": "number"
    },
    "revenue_share": {
      "type": "number",
      "minimum": 0
    },
    "net_settlement": {
      "type": "number"
    },
    "formula_version": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": [
        "DRAFT",
        "RECONCILED",
        "DISPUTED",
        "APPROVED",
        "SETTLED",
        "BLOCKED"
      ]
    },
    "source_system": {
      "type": "string",
      "minLength": 1
    },
    "approved_by": {
      "type": [
        "string",
        "null"
      ]
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}

