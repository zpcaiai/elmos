{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elmos.dev/contracts/commercial-loop/motion-profile.schema.json",
  "title": "Commercial Motion Profile",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "motion",
    "required",
    "catalog_defined",
    "contract_boundary_defined",
    "delivery_and_support_configured",
    "evidence_refs"
  ],
  "properties": {
    "motion": {
      "enum": [
        "DIRECT_SALES",
        "POC_LED_SALES",
        "ENTERPRISE_SUBSCRIPTION",
        "PROFESSIONAL_SERVICES",
        "PARTNER_LED_DELIVERY",
        "MANAGED_MIGRATION_SERVICE"
      ]
    },
    "required": {
      "const": true
    },
    "catalog_defined": {
      "const": true
    },
    "contract_boundary_defined": {
      "const": true
    },
    "delivery_and_support_configured": {
      "const": true
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}

