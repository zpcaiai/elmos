{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elmos.dev/contracts/enterprise-platform/capability-binding.schema.json",
  "title": "Enterprise Capability Binding",
  "type": "object",
  "additionalProperties": false,
  "required": ["capability_id", "component", "version", "available", "external_execution_required", "evidence_refs"],
  "properties": {
    "capability_id": {"type": "string", "minLength": 1},
    "component": {"type": "string", "minLength": 1},
    "version": {"type": "string", "minLength": 1},
    "available": {"const": true},
    "external_execution_required": {"const": true},
    "evidence_refs": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}
  }
}
