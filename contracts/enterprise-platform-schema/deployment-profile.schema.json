{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elmos.dev/contracts/enterprise-platform/deployment-profile.schema.json",
  "title": "Independent Enterprise Deployment Profile",
  "type": "object",
  "additionalProperties": false,
  "required": ["profile_id", "mode", "required", "contract_declared", "responsibility_matrix_complete", "data_flow_approved", "evidence_refs"],
  "properties": {
    "profile_id": {"type": "string", "minLength": 1},
    "mode": {"$ref": "#/$defs/mode"},
    "required": {"const": true},
    "contract_declared": {"const": true},
    "responsibility_matrix_complete": {"const": true},
    "data_flow_approved": {"const": true},
    "evidence_refs": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}
  },
  "$defs": {"mode": {"enum": ["SAAS_SHARED", "SAAS_DEDICATED_RUNNER", "HYBRID_PRIVATE_RUNNER", "SELF_HOSTED", "AIR_GAPPED"]}}
}
