{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elmos.dev/contracts/enterprise-platform/platform-artifact.schema.json",
  "title": "Immutable Enterprise Platform Artifact",
  "type": "object",
  "additionalProperties": false,
  "required": ["platform_version", "artifact_digest", "immutable", "signed", "sbom_ref", "provenance_ref", "batch1_through11_control_planes_verified", "evidence_refs"],
  "properties": {
    "platform_version": {"type": "string", "minLength": 1},
    "artifact_digest": {"type": "string", "pattern": "^[A-Fa-f0-9]{64}$"},
    "immutable": {"const": true},
    "signed": {"const": true},
    "sbom_ref": {"type": "string", "minLength": 1},
    "provenance_ref": {"type": "string", "minLength": 1},
    "batch1_through11_control_planes_verified": {"const": true},
    "evidence_refs": {"$ref": "#/$defs/refs"}
  },
  "$defs": {"refs": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}}
}
