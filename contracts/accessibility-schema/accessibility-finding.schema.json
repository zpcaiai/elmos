{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.elmos.io/frontend/accessibility-finding.v1.schema.json",
  "title": "Accessibility finding",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "organizationId", "findingId", "profileId", "targetStandard", "status", "severity", "evidenceRefs"],
  "properties": {
    "schemaVersion": {"const": "1.0"},
    "organizationId": {"type": "string", "minLength": 1},
    "findingId": {"type": "string", "minLength": 1},
    "profileId": {"type": "string", "minLength": 1},
    "targetStandard": {"type": "string", "minLength": 1},
    "successCriterion": {"type": "string", "minLength": 1},
    "status": {"enum": ["VIOLATION", "NEEDS_REVIEW", "PASS_AUTOMATED", "PASS_MANUAL", "NOT_APPLICABLE", "ACCEPTED_EXCEPTION"]},
    "severity": {"enum": ["INFO", "MINOR", "MAJOR", "CRITICAL"]},
    "exceptionExpiresAt": {"type": "string", "format": "date-time"},
    "approvedBy": {"type": "string", "minLength": 1},
    "evidenceRefs": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}, "uniqueItems": true}
  },
  "allOf": [{"if": {"properties": {"status": {"const": "ACCEPTED_EXCEPTION"}}}, "then": {"required": ["exceptionExpiresAt", "approvedBy"]}}]
}
