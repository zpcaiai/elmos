{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "elmos.project-synthesis.request.v1",
  "title": "ELMOS approved project synthesis request",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "project",
    "actors",
    "entity",
    "requirements",
    "acceptance_criteria",
    "constraints",
    "assumptions",
    "quality_attributes",
    "targets",
    "open_questions",
    "approval"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "description", "namespace"],
      "properties": {
        "id": {"type": "string", "pattern": "^PRJ-[A-Z0-9-]+$"},
        "name": {"type": "string", "pattern": "^[a-z][a-z0-9-]{1,62}[a-z0-9]$"},
        "description": {"type": "string", "minLength": 1},
        "namespace": {"type": "string", "pattern": "^[a-z][a-z0-9_]*(\\.[a-z][a-z0-9_]*)+$"}
      }
    },
    "actors": {"type": "array", "items": {"type": "object"}},
    "entity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["singular", "plural", "fields"],
      "properties": {
        "singular": {"type": "string", "pattern": "^[a-z][a-z0-9_]{0,62}$"},
        "plural": {"type": "string", "pattern": "^[a-z][a-z0-9_]{0,62}$"},
        "fields": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "type", "required"],
            "properties": {
              "name": {"type": "string", "pattern": "^[a-z][a-z0-9_]{0,62}$"},
              "type": {"enum": ["string", "integer", "number", "boolean", "datetime"]},
              "required": {"type": "boolean"}
            }
          }
        }
      }
    },
    "requirements": {"type": "array", "minItems": 3, "items": {"type": "object"}},
    "acceptance_criteria": {"type": "array", "minItems": 3, "items": {"type": "object"}},
    "constraints": {"type": "array", "items": {"type": "object"}},
    "assumptions": {"type": "array", "items": {"type": "object"}},
    "quality_attributes": {"type": "array", "items": {"type": "object"}},
    "targets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["language", "framework", "runtime", "port"],
        "properties": {
          "language": {"enum": ["java", "python", "csharp"]},
          "framework": {"enum": ["spring-boot", "fastapi", "aspnet-core"]},
          "runtime": {"enum": ["21", "3.12", "10.0"]},
          "port": {"type": "integer", "minimum": 1024, "maximum": 65535}
        }
      }
    },
    "open_questions": {"type": "array", "items": {"type": "object"}},
    "approval": {
      "type": "object",
      "required": ["status"],
      "properties": {
        "status": {"enum": ["DRAFT", "APPROVED"]},
        "approved_by": {"type": "string"},
        "approved_at": {"type": "string", "format": "date-time"},
        "approved_payload_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
      }
    }
  }
}
