{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "elmos.project-synthesis.agent-runtime.v1",
  "title": "ELMOS Agent Runtime Plan",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "agents",
    "steps",
    "budgets",
    "policy_ref"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "run_id": {
      "type": "string"
    },
    "agents": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "role",
          "capabilities"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "role": {
            "type": "string"
          },
          "capabilities": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "model_route": {
            "type": "string"
          }
        }
      }
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "budgets": {
      "type": "object"
    },
    "policy_ref": {
      "type": "string"
    },
    "checkpoint_policy": {
      "type": "object"
    }
  }
}