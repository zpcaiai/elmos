{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "elmos.project-synthesis.domain-pack.v1",
  "title": "ELMOS Domain Pack",
  "type": "object",
  "required": [
    "schema_version",
    "id",
    "version",
    "domain",
    "glossary",
    "models",
    "workflows",
    "permissions",
    "tests"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "id": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "domain": {
      "type": "string"
    },
    "glossary": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "models": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "workflows": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "permissions": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "integrations": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "tests": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "policies": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "signature": {
      "type": "string"
    }
  }
}